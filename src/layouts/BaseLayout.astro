---
import SplashOverlay from '../components/intro/SplashOverlay.astro';
import GlobalMenu from '../components/layout/GlobalMenu.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  pageClass?: string;
  showSplash?: boolean;
}

const {
  title,
  description = '',
  pageClass = '',
  showSplash = false,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
</head>
<body class={pageClass}>
  {showSplash && <SplashOverlay />}
  <GlobalMenu />
  <slot name="nav" />
  <slot />
</body>
</html>
