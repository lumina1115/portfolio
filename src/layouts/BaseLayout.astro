---
import SplashOverlay from '../components/intro/SplashOverlay.astro';
import PageLoadOverlay from '../components/intro/PageLoadOverlay.astro';
import GlobalMenu from '../components/layout/GlobalMenu.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  pageClass?: string;
  showSplash?: boolean;
  showPageLoader?: boolean;
}

const {
  title,
  description = '',
  pageClass = '',
  showSplash = false,
  showPageLoader,
} = Astro.props;

const shouldShowPageLoader = showPageLoader ?? !showSplash;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  {shouldShowPageLoader && (
    <script is:inline>
      document.documentElement.classList.add('is-page-load-pending');
    </script>
  )}
</head>
<body class={pageClass}>
  {showSplash && <SplashOverlay />}
  {shouldShowPageLoader && <PageLoadOverlay />}
  <GlobalMenu />
  <slot name="nav" />
  <slot />
</body>
</html>
