<script>
  const setupChapterSidebar = () => {
    const chapters = Array.from(document.querySelectorAll('.p2-root [data-chapter-section]'))
      .filter((chapter) => chapter instanceof HTMLElement);

    if (!chapters.length) {
      return;
    }

    let activeChapter = null;
    let ticking = false;

    const activateChapter = (chapter) => {
      if (activeChapter === chapter) {
        return;
      }

      activeChapter = chapter;
      chapters.forEach((item) => {
        item.classList.toggle('is-active', item === chapter);
      });
    };

    const getDocumentTop = (element) => element.getBoundingClientRect().top + window.scrollY;

    const getActiveChapter = () => {
      const anchorY = window.scrollY + window.innerHeight * 0.32;
      const currentChapter = chapters.find((chapter) => {
        const top = getDocumentTop(chapter);
        const bottom = top + chapter.offsetHeight;

        return anchorY >= top && anchorY < bottom;
      });

      if (currentChapter) {
        return currentChapter;
      }

      return chapters.reduce((closest, chapter) => {
        const distance = Math.abs(chapter.getBoundingClientRect().top - window.innerHeight * 0.32);
        const closestDistance = Math.abs(closest.getBoundingClientRect().top - window.innerHeight * 0.32);

        return distance < closestDistance ? chapter : closest;
      }, chapters[0]);
    };

    const updateActiveChapter = () => {
      activateChapter(getActiveChapter());
      ticking = false;
    };

    const requestUpdate = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateActiveChapter);
        ticking = true;
      }
    };

    activateChapter(getActiveChapter());
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
    window.addEventListener('load', requestUpdate, { once: true });

    if ('ResizeObserver' in window) {
      const resizeObserver = new ResizeObserver(requestUpdate);
      chapters.forEach((chapter) => resizeObserver.observe(chapter));
    }
  };

  const setupRailMenuVisibility = () => {
    const chapters = Array.from(document.querySelectorAll('.p2-root [data-chapter-section]'));
    const firstChapter = chapters[0];
    const lastChapter = chapters[chapters.length - 1];

    if (!(firstChapter instanceof HTMLElement) || !(lastChapter instanceof HTMLElement)) {
      return;
    }

    const setVisible = (isVisible) => {
      document.body.classList.toggle('menu-on-rail', isVisible);
    };

    let ticking = false;

    const updateVisibility = () => {
      const stickyOffset = window.innerHeight * 0.12;
      const firstTop = firstChapter.getBoundingClientRect().top + window.scrollY;
      const lastBottom = lastChapter.getBoundingClientRect().bottom + window.scrollY;
      const scrollAnchor = window.scrollY + stickyOffset;

      setVisible(scrollAnchor >= firstTop && window.scrollY < lastBottom);
      ticking = false;
    };

    const requestUpdate = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateVisibility);
        ticking = true;
      }
    };

    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
    updateVisibility();
  };

  const setupProject2FinalReveal = () => {
    const reveal = document.querySelector('[data-p2-modular-reveal]');
    if (!(reveal instanceof HTMLElement)) {
      return;
    }

    let progress = 0;

    const setReveal = (nextProgress) => {
      progress = Math.min(1, Math.max(0, nextProgress));
      const easedProgress = 1 - Math.pow(1 - progress, 3);
      const scale = 1.05 - easedProgress * 0.05;

      reveal.style.setProperty('--p2-final-reveal', easedProgress.toFixed(4));
      reveal.style.setProperty('--p2-final-scale', scale.toFixed(4));
    };

    reveal.addEventListener('pointerenter', () => {
      setReveal(Math.max(progress, 0.36));
    });
    reveal.addEventListener('wheel', (event) => {
      setReveal(progress + event.deltaY * 0.0016);
    }, { passive: true });
    reveal.querySelectorAll('img').forEach((image) => {
      image.addEventListener('load', () => setReveal(progress), { once: true });
    });
    setReveal(0);
  };

  const setupProject2DetailGallery = () => {
    const reveal = document.querySelector('[data-p2-render-reveal]');
    const tiltItems = Array.from(document.querySelectorAll('[data-p2-render-tilt]'));

    if (reveal instanceof HTMLElement) {
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.2 });
        observer.observe(reveal);
      } else {
        reveal.classList.add('is-visible');
      }
    }

    tiltItems.forEach((item) => {
      if (!(item instanceof HTMLElement)) {
        return;
      }

      const resetTilt = () => {
        item.style.setProperty('--rx', '0deg');
        item.style.setProperty('--ry', '0deg');
        item.style.setProperty('--shine-x', '50%');
      };

      item.addEventListener('pointermove', (event) => {
        const rect = item.getBoundingClientRect();
        const x = (event.clientX - rect.left) / Math.max(1, rect.width);
        const y = (event.clientY - rect.top) / Math.max(1, rect.height);
        item.style.setProperty('--rx', `${(0.5 - y) * 8}deg`);
        item.style.setProperty('--ry', `${(x - 0.5) * 10}deg`);
        item.style.setProperty('--shine-x', `${x * 100}%`);
      });

      item.addEventListener('pointerleave', resetTilt);
      resetTilt();
    });
  };

  setupChapterSidebar();
  setupRailMenuVisibility();
  setupProject2FinalReveal();
  setupProject2DetailGallery();
</script>

