    grid-template-columns: clamp(1rem, 1.8vw, 2rem) minmax(0, 1fr);
    grid-template-areas: 'rule copy';
    column-gap: clamp(0.52rem, 0.8vw, 0.72rem);
    align-items: start;
    width: calc(100% - var(--p2-rail-axis) - clamp(0.55rem, 1vw, 0.9rem));
    margin-left: var(--p2-rail-axis);
    padding-top: 0.05rem;
    color: rgba(225, 203, 166, 0.22);
    text-decoration: none;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 1;
  }

  .p2-chapter.is-active .p2-sticky-tag {
    color: var(--p2-rail-text);
    opacity: 1;
    transform: translateY(0);
  }

  .p2-sidebar-rule {
    grid-area: rule;
    width: 100%;
    height: 1px;
    margin-top: calc(var(--p2-sidebar-index-size) * 0.4);
    background: currentColor;
    transform-origin: left center;
    transform: scaleX(0.42);
    transition: inherit;
  }

  .p2-chapter.is-active .p2-sidebar-rule {
    transform: scaleX(1);
  }

  .p2-sidebar-title {
    display: block;
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
  }

  .p2-sidebar-title span {
    display: block;
  }

  .p2-sidebar-copy {
    grid-area: copy;
    position: relative;
    display: grid;
    gap: 0.68rem;
    justify-items: start;
    min-width: 0;
    padding-block: 0.32rem;
    isolation: isolate;
  }

  .p2-sidebar-index {
    position: relative;
    z-index: 0;
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
    font-size: var(--p2-sidebar-index-size);
    font-weight: 700;
    line-height: 0.7;
    letter-spacing: -0.1em;
    color: currentColor;
    opacity: 0.16;
  }

  .p2-sidebar-title {
    color: currentColor;
    font-size: clamp(0.86rem, 1.05vw, 1.18rem);
    line-height: 1.48;
    letter-spacing: 0.18em;
    text-wrap: balance;
  }

  .p2-sidebar-subtitle {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 500;
    line-height: 1.58;
    letter-spacing: 0.1em;
    color: rgba(225, 203, 166, 0.24);
    transition: inherit;
  }

  .p2-chapter.is-active .p2-sidebar-subtitle {
    color: rgba(225, 203, 166, 0.48);
  }

  .p2-section-main {
    display: grid;
    flex: 1 1 auto;
    min-width: 0;
    row-gap: var(--p2-gap);
  }

  .p2-rect-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--p2-gap);
  }

  .p2-rect-card {
    position: relative;
    width: 100%;
    padding: var(--p2-card-pad);
    background: var(--p2-surface);
    color: var(--p2-text);
    border: 0;
    border-radius: 0;
    box-shadow: none;
    overflow: hidden;
  }

  .p2-rect-card[data-section-label]::before {
    content: attr(data-section-label);
    display: block;
    margin-bottom: 1.1rem;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(var(--p2-accent-rgb), 0.74);
  }

  #p2-insight .p2-rect-card[data-section-label]::before {
    display: none;
  }

  .p2-eyebrow,
  .p2-kicker {
    margin: 0 0 0.7rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--p2-accent);
  }

  .p2-card-head {
    max-width: min(48rem, 100%);
    margin-bottom: clamp(1.4rem, 3vw, 2.5rem);
  }

  .p2-root h2,
  .p2-root h3,
  .p2-root p {
    margin-top: 0;
  }

  .p2-root h2 {
    max-width: min(58rem, 100%);
    margin-bottom: 1rem;
    color: var(--p2-accent);
    font-size: var(--p2-type-h2);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .p2-root h3 {
    margin-bottom: 0.75rem;
    color: var(--p2-accent);
    font-size: var(--p2-type-h3);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .p2-root p {
    max-width: min(42rem, 100%);
    color: var(--p2-text-dim);
    font-size: var(--p2-type-body);
    line-height: var(--p2-leading-body);
  }

  .p2-lead {
    font-size: clamp(1.2rem, 2.2vw, 1.55rem) !important;
    line-height: 1.7 !important;
    color: rgba(26, 26, 26, 0.72) !important;
  }

  .p2-context-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.96fr);
    column-gap: var(--p2-gap);
    row-gap: clamp(0.9rem, 1.35vw, 1.25rem);
    align-items: start;
    min-height: 31rem;
  }

  .p2-context-copy-panel {
    grid-column: 1;
    grid-row: 1;
    display: flex;
    min-width: 0;
    padding-top: 0;
    flex-direction: column;
    justify-content: flex-start;
    gap: 0;
  }

  .p2-context-detail-panel {
    grid-column: 1;
    grid-row: 2;
    display: flex;
    min-width: 0;
    flex-direction: column;
    justify-content: flex-start;
    align-self: center;
    gap: var(--p2-gap);
  }

  .p2-root .p2-context-title {
    max-width: none;
    margin: 0;
    padding-top: 0.15rem;
    color: var(--p2-accent) !important;
    font-size: var(--p2-type-h2) !important;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    white-space: nowrap;
    text-wrap: nowrap;
  }

  .p2-context-body {
    max-width: 31.5rem;
    margin: 0;
    padding-left: 0;
    color: var(--p2-text-dim);
    font-size: var(--p2-type-body) !important;
    line-height: var(--p2-leading-long) !important;
    text-align: justify;
    text-justify: inter-ideograph;
    hanging-punctuation: allow-end;
  }

  .p2-context-key {
    color: var(--p2-accent);
    font-weight: 800;
  }

  .p2-stat-rail {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    align-items: end;
    padding-top: 0.4rem;
  }

  .p2-stat {
    display: flex;
    min-height: auto;
    padding: 0;
    flex-direction: column;
    gap: 0.4rem;
    background: transparent;
    border-left: 0;
  }

  .p2-stat-note {
    color: rgba(26, 26, 26, 0.62);
    font-size: var(--p2-type-caption);
    letter-spacing: 0.02em;
    line-height: 1.5;
  }

  .p2-stat-row {
    display: inline-flex;
    align-items: flex-end;
    gap: 0.34rem;
    width: fit-content;
    max-width: 100%;
    padding: 0 0.18rem 0.32rem 0;
    color: var(--p2-accent);
    border-bottom: 1.5px solid rgba(var(--p2-accent-rgb), 0.14);
  }

  .p2-stat-num {
    display: block;
    color: currentColor;
    font-family: var(--font-sans);
    font-size: clamp(2.35rem, 4.15vw, 3.35rem);
    font-weight: 800;
    line-height: 0.86;
    letter-spacing: 0;
  }

  .p2-stat-unit {
    display: block;
    margin: 0 0 0.2rem;
    color: currentColor;
    font-family: var(--font-sans);
    font-size: clamp(0.62rem, 0.72vw, 0.78rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0;
    text-transform: uppercase;
    transform: translateY(-0.26rem);
  }

  .p2-context-media {
    grid-column: 2;
    grid-row: 2;
    position: relative;
    align-self: start;
    justify-self: stretch;
    margin: 0;
    display: flex;
    align-items: stretch;
    width: 100%;
    min-width: 0;
    height: 22rem;
    overflow: hidden;
    background: var(--p2-surface);
  }

  .p2-context-media img {
    display: block;
    width: 106%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    object-position: center;
    transform: translateX(-2.5%) scale(1.06);
    transform-origin: center;
    -webkit-mask-image:
      linear-gradient(90deg, transparent 0%, #000 18%, #000 82%, transparent 100%),
      linear-gradient(180deg, transparent 0%, #000 13%, #000 87%, transparent 100%);
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(90deg, transparent 0%, #000 18%, #000 82%, transparent 100%),
      linear-gradient(180deg, transparent 0%, #000 13%, #000 87%, transparent 100%);
    mask-composite: intersect;
  }

  .p2-root[data-project="project-4"] .p2-context-media img {
    object-position: center 48%;
    transform: translateX(-2.5%) scale(1.16);
  }

  .p2-context-media::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(90deg, var(--p2-surface) 0%, rgba(251, 247, 237, 0.94) 10%, rgba(251, 247, 237, 0.62) 22%, rgba(251, 247, 237, 0) 44%);
  }

  .p2-two-up > * {
    grid-column: span 6;
  }

  .p2-insight-merged-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 0;
    align-items: stretch;
  }

  .p2-insight-merged-card--evidence-only {
    grid-template-columns: 1fr;
  }

  .p2-insight-merged-panel {
    min-width: 0;
  }

  .p2-insight-merged-panel + .p2-insight-merged-panel {
    padding-left: clamp(1.2rem, 2.2vw, 2rem);
  }

  .p2-segment-list {
    display: grid;
    gap: 1rem;
  }

  .p2-segment-list {
    gap: clamp(1.4rem, 2.7vw, 2.4rem);
  }

  .p2-segment {
    position: relative;
    display: grid;
    grid-template-columns: minmax(7rem, 0.35fr) minmax(0, 1fr);
    align-items: center;
    gap: 0;
    min-height: clamp(8.5rem, 14vw, 11.5rem);
  }

  .p2-segment:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .p2-segment-media {
    position: relative;
    z-index: 3;
    grid-column: 1 / 2;
    grid-row: 1;
    align-self: center;
    justify-self: start;
    margin: calc(-0.8rem + var(--persona-index, 0) * 0.2rem) -2.2rem 0 0;
    height: clamp(8.2rem, 13vw, 11.2rem);
  }


  .p2-segment-persona[style*="--persona-index: 1"] .p2-segment-media {
    align-self: end;
    margin-top: -1.4rem;
  }

  .p2-segment-media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: left bottom;
  }

  .p2-segment-card-body {
    position: relative;
    z-index: 1;
    grid-column: 2 / 3;
    grid-row: 1;
    transform: translateX(-2em);
    min-height: clamp(4.8rem, 7.4vw, 6.4rem);
    padding: clamp(1rem, 1.6vw, 1.45rem) clamp(1.2rem, 2vw, 1.8rem) clamp(1rem, 1.55vw, 1.35rem) clamp(2rem, 4vw, 3.7rem);
    background: rgba(255, 255, 255, 0.78);
    border: 1.5px solid rgba(200, 128, 11, 0.82);
    border-radius: 0 0.75rem 0.75rem 0;
    box-shadow: 0 0 1rem rgba(200, 128, 11, 0.22);
  }

  .p2-segment-persona-label {
    display: block;
    margin-bottom: 0.42rem;
    color: var(--p2-accent);
    font-size: clamp(1.05rem, 1.35vw, 1.28rem);
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .p2-segment h3 {
    margin: 0 0 0.45rem;
    color: rgba(114, 76, 54, 0.78);
    font-size: clamp(0.78rem, 0.86vw, 0.9rem);
    font-weight: 700;
    line-height: 1.15;
  }

  .p2-segment p {
    margin: 0;
    color: rgba(114, 76, 54, 0.68);
    font-size: clamp(0.84rem, 0.94vw, 0.96rem);
    font-weight: 400;
    line-height: 1.7;
  }

  .p2-segment-key {
    color: var(--p2-accent);
    font-weight: 800;
  }


  .p2-evidence-card {
    display: grid;
    align-content: start;
    gap: clamp(0.9rem, 1.5vw, 1.25rem);
  }

  .p2-evidence-paper {
    margin: 0;
  }

  .p2-evidence-paper img {
    width: 100%;
    height: clamp(10rem, 17vw, 14rem);
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .p2-evidence-paper figcaption {
    margin-top: 0.55rem;
    color: rgba(26, 26, 26, 0.58);
    font-size: clamp(0.7rem, 0.78vw, 0.82rem);
    line-height: 1.55;
  }

  .p2-evidence-quote-box {
    padding: clamp(1rem, 1.6vw, 1.35rem) clamp(1.1rem, 2vw, 1.6rem);
    background: rgba(255, 255, 255, 0.78);
    border: 1.5px solid rgba(200, 128, 11, 0.82);
    border-radius: 0.75rem;
    box-shadow: 0 0 1rem rgba(200, 128, 11, 0.22);
  }

  .p2-evidence-quote-box p {
    margin: 0;
    color: var(--p2-accent);
    font-size: clamp(0.9rem, 1vw, 1.05rem);
    font-weight: 800;
    line-height: 1.72;
  }

  .p2-quote {
    color: rgba(26, 26, 26, 0.72) !important;
    font-size: clamp(1.15rem, 1.8vw, 1.35rem) !important;
    line-height: var(--p2-leading-body) !important;
    font-weight: 700;
  }

  .p2-gap-grid,
  .p2-goal-grid,
  .p2-detail-grid,
  .p2-system-map,
  .p2-color-card {
    display: grid;
    gap: 1rem;
  }

  .p2-gap-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .p2-gap-card .p2-card-head {
    max-width: none;
    margin-bottom: 1rem;
  }

  .p2-gap-card .p2-card-head h2 {
    max-width: none;
    margin-bottom: 0;
    white-space: nowrap;
  }

  .p2-journey-image-card::before {
    display: none !important;
  }

  .p2-journey-image-label {
    margin: 0 0 1.1rem;
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(var(--p2-accent-rgb), 0.74);
  }

  .p2-gap-item,
  .p2-goal,
  .p2-detail,
  .p2-system-node,
  .p2-color-card section {
    padding: 1rem;
    background: rgba(240, 229, 211, 0.76);
    border-top: 2px solid var(--p2-accent);
  }

  .p2-gap-media {
    margin: 0 0 0.85rem;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.48);
  }

  .p2-gap-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .p2-gap-item span,
  .p2-goal-index,
  .p2-detail span {
    display: block;
    margin-bottom: 1rem;
    color: var(--p2-accent);
    font-family: var(--font-sans);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.12em;
  }

  .p2-gap-item h3,
  .p2-detail h3,
  .p2-system-node h3 {
    margin-bottom: 0.55rem;
    font-size: var(--p2-type-h5);
    line-height: 1.12;
  }


  .p2-structure-card {
    display: grid;
    grid-template-columns: minmax(18rem, 0.9fr) minmax(20rem, 1.1fr);
    align-items: center;
    gap: clamp(1.2rem, 3vw, 3rem);
  }

  .p2-structure-media {
    margin: 0;
    min-width: 0;
  }

  .p2-structure-media img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .p2-structure-list {
    display: grid;
    gap: clamp(1.1rem, 2.3vw, 2rem);
  }

  .p2-structure-row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(5.2rem, auto) minmax(0, 1fr);
    align-items: center;
    gap: clamp(0.9rem, 1.6vw, 1.35rem);
    min-height: clamp(3.3rem, 5vw, 4.4rem);
    padding: 0.75rem clamp(1rem, 1.8vw, 1.5rem);
    background: rgba(255, 255, 255, 0.72);
    border: 1.5px solid var(--p2-accent);
    border-radius: 999px;
    box-shadow: 0 0 1rem rgba(200, 128, 11, 0.18);
  }

  .p2-structure-row::before {
    content: "";
    position: absolute;
    right: calc(100% + 0.5rem);
    top: 50%;
    width: clamp(3rem, 7vw, 6rem);
    height: 2px;
    background: var(--p2-accent);
    transform: translateY(-50%);
  }

  .p2-structure-row::after {
    content: "";
    position: absolute;
    right: calc(100% + 0.1rem);
    top: 50%;
    border-top: 0.45rem solid transparent;
    border-bottom: 0.45rem solid transparent;
    border-left: 0.75rem solid var(--p2-accent);
    transform: translateY(-50%);
  }

  .p2-structure-row span {
    color: rgba(58, 44, 31, 0.9);
    font-size: clamp(1rem, 1.35vw, 1.25rem);
    font-weight: 800;
    white-space: nowrap;
  }

  .p2-structure-row p {
    margin: 0;
    padding-left: clamp(0.9rem, 1.6vw, 1.35rem);
    border-left: 1px solid rgba(26, 26, 26, 0.16);
    color: rgba(58, 44, 31, 0.78);
    font-size: clamp(0.95rem, 1.15vw, 1.1rem);
    font-weight: 700;
    line-height: 1.5;
  }

  .p2-process {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.75rem;
    margin-bottom: clamp(1.6rem, 3vw, 2.4rem);
  }

  .p2-process-step {
    position: relative;
    min-height: 8.5rem;
    padding: 1rem;
    background: var(--p2-surface-2);
    border-bottom: 2px solid var(--p2-accent);
  }

  .p2-process-step span {
    display: block;
    color: var(--p2-accent);
    font-family: var(--font-sans);
    font-weight: 800;
    margin-bottom: 1.4rem;
  }

  .p2-process-step p,
  .p2-gap-item p,
  .p2-goal p,
  .p2-detail p,
  .p2-system-node p,
  .p2-scenario p,
  .p2-color-card p {
    margin-bottom: 0;
    font-size: var(--p2-type-dense);
    line-height: var(--p2-leading-dense);
  }

  .p2-gap-item p {
    line-height: 1.55;
  }

  .p2-placeholder {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 18rem;
    padding: 1rem;
    border: 1px solid rgba(var(--p2-accent-rgb), 0.32);
    border-radius: 10px;
    background:
      linear-gradient(90deg, rgba(var(--p2-accent-rgb), 0.08) 1px, transparent 1px),
      linear-gradient(180deg, rgba(var(--p2-accent-rgb), 0.08) 1px, transparent 1px),
      rgba(255, 255, 255, 0.36);
    background-size: 2.4rem 2.4rem;
    color: var(--p2-accent);
    overflow: hidden;
  }

  .p2-placeholder p {
    position: relative;
    z-index: 2;
    margin: 0;
    color: rgba(var(--p2-accent-rgb), 0.86);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-align: center;
    text-transform: uppercase;
  }

  .p2-placeholder-grid {
    position: absolute;
    inset: 1.2rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    opacity: 0.72;
  }

  .p2-placeholder-grid span,
  .p2-placeholder--small span {
    border: 1px solid rgba(var(--p2-accent-rgb), 0.35);
    border-radius: 8px;
    background: rgba(251, 247, 237, 0.42);
  }

  .p2-mood-card,
  .p2-position-card {
    min-height: 23rem;
  }

  .p2-root[data-project="project-2"] .p2-moodboard-card {
    display: grid;
    grid-template-columns: minmax(26rem, 1.35fr) minmax(18rem, 0.65fr);
    grid-template-rows: auto minmax(0, 1fr);
    column-gap: clamp(1.5rem, 3.2vw, 3.4rem);
    row-gap: 1.1rem;
    align-items: center;
    min-height: 23rem;
    overflow: hidden;
  }

  .p2-root[data-project="project-2"] .p2-moodboard-card::before {
    grid-column: 1 / -1;
    grid-row: 1;
    margin-bottom: 0;
  }

  .p2-moodboard-collage {
    position: relative;
    display: grid;
    grid-column: 1;
    grid-row: 2;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    grid-template-rows: repeat(8, minmax(0, 1fr));
    gap: clamp(0.35rem, 0.8vw, 0.7rem);
    height: clamp(17rem, 34vw, 26rem);
    min-width: 0;
  }

  .p2-moodboard-image {
    position: relative;
    margin: 0;
