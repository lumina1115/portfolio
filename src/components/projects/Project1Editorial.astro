---
const cdnBase = 'https://portfolio-image-cdn.zongxz66.workers.dev';
const { project } = Astro.props as { project: any };
const heroTitle = project.data.title?.split(' — ')[0] ?? project.data.title;
const heroSubtitle = project.data.subtitle ?? project.data.title?.split(' — ')[1] ?? '';
const heroSummary = project.data.summary;

// 标注坐标调节说明：
// anchor 是箭头指向产品结构的位置，label 是文字卡片的位置。
// x / y 都是相对于“视频真实画面”的百分比坐标：x=0 在最左，x=100 在最右；y=0 在最上，y=100 在最下。
// 例如想把文字往右移，就增加 label.x；想把箭头指向点往下移，就增加 anchor.y。
const explodedAnnotations = [
  {
    id: 'side-support',
    title: '硬质硅胶外壳',
    text: '高强度树脂材料，提供踝关节稳固支撑',
    anchor: { x: 35, y: 65 },
    label: { x: 8, y: 65 },
  },
  {
    id: 'adjust-system',
    title: '紧固绑带',
    text: '多点位快速调节设计，适应不同脚部维度需求',
    anchor: { x: 58, y: 60 },
    label: { x: 78, y: 26 },
  },
  {
    id: 'base',
    title: '模块化鞋底',
    text: '流线型设计增强运动时尚感',
    anchor: { x: 51, y: 87 },
    label: { x: 78, y: 80 },
  },
  {
    id: 'inner-fabric',
    title: '柔软内衬',
    text: '内置传感面料 ThermorFit，实时监测步态与足底压力',
    anchor: { x: 25, y: 40 },
    label: { x: 8, y: 30 },
  },
];
---

<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" />

<main class="p1-root">
  <section class="p1-hero">
    <div class="p1-hero-shell">
      <div class="p1-hero-media" aria-hidden="true">
        <img loading="lazy" decoding="async"
          src={`${cdnBase}/project-1/cover.jpg`}
          alt=""
          class="p1-hero-img"
        />
      </div>

      <div class="p1-hero-copy">
        <p class="p1-caption p1-hero-caption">{heroTitle} / project 01</p>

        <div class="p1-kicker-row">
          <span class="p1-hero-index">01</span>
          <span class="p1-kicker-line"></span>
          <span class="p1-kicker-text">工业设计 / 智能穿戴 / 医疗机能</span>
        </div>

        <div class="p1-copy-stack">
          <p class="p1-overline">case study</p>
          <h1 class="p1-hero-title">{heroTitle}</h1>
          <p class="p1-hero-sub">{heroSubtitle}</p>
        </div>

        <p class="p1-hero-desc">{heroSummary}</p>

        <div class="p1-hero-tags">
          <span>AFO 三点力学矫形</span>
          <span>柔性压力传感监测</span>
          <span>模块化磁吸快穿脱</span>
        </div>
      </div>
    </div>
  </section>

  <section class="p1-section p1-context">
    <div class="p1-rect-grid p1-rect-grid--context">
      <article class="p1-rect-card p1-card-context-merged" data-section-label="设计背景">
        <div class="p1-context-copy-panel">
          <p class="p1-context-title">痉挛性脑性瘫痪发病率高，步态问题突出。</p>
        </div>

        <div class="p1-context-detail-panel">
          <p class="p1-context-body">
            痉挛性脑瘫是儿童高发的运动障碍疾病，足部肌张力紊乱常引发足内翻，造成重心偏移、步态不稳与更高跌倒风险。与此同时，患儿往往难以准确表达疼痛与不适，传统矫形器又普遍外观医疗化，容易带来病耻感与穿戴抗拒。市场仍缺少兼顾步态数据采集、医患沟通与儿童审美的智能矫形设备。
          </p>

          <div class="p1-stat-rail">
            <div class="p1-stat">
              <span class="p1-stat-note">每千名活产婴儿脑瘫发病率</span>
              <div class="p1-stat-row">
                <span class="p1-stat-num">2–3.4</span>
                <span class="p1-stat-unit">例</span>
              </div>
            </div>
            <div class="p1-stat">
              <span class="p1-stat-note">其中痉挛型占比</span>
              <div class="p1-stat-row">
                <span class="p1-stat-num">75</span>
                <span class="p1-stat-unit">%</span>
              </div>
            </div>
          </div>
        </div>

        <figure class="p1-context-media">
          <img loading="lazy" decoding="async"
            src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMHajEen4wRm27yrMh7iw4AAfFaq-A2AALqEWsbbjqJVbS5QfLRy_q0AQADAgADdwADPAQ.png"
            alt="背景调研图"
          />
        </figure>
      </article>
    </div>
  </section>

  <section class="p1-section p1-pain">
    <div class="p1-pain-grid" data-section-label="痛点分析">
      <article class="p1-rect-card p1-pain-card">
        <figure class="p1-pain-media p1-pain-media--a">
          <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMMajFexxuqLKbtPJMakJpLUs53BJUAAhETaxtuOolVWYdoNIcc9CoBAAMCAAN3AAM8BA.png" alt="足内翻痛点图" />
          <span class="p1-pain-tag">痛点 01</span>
        </figure>
        <div class="p1-pain-copy">
          <h3 class="p1-pain-title">足内翻</h3>
          <p class="p1-pain-text">足部肌张力紊乱会持续拉扯步态，导致重心偏移、步态不稳与更高跌倒风险。</p>
        </div>
      </article>

      <article class="p1-rect-card p1-pain-card">
        <figure class="p1-pain-media p1-pain-media--b">
          <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMNajFe_Ht_ja9cu3xVBbaGGdAB86AAAhYTaxtuOolV0Q8bZvj3L5sBAAMCAAN3AAM8BA.png" alt="沟通障碍痛点图" />
          <span class="p1-pain-tag">痛点 02</span>
        </figure>
        <div class="p1-pain-copy">
          <h3 class="p1-pain-title">沟通障碍</h3>
          <p class="p1-pain-text">患儿难以准确表达疼痛与不适，家长和康复师也难以及时判断真实身体状态。</p>
        </div>
      </article>

      <article class="p1-rect-card p1-pain-card">
        <figure class="p1-pain-media p1-pain-media--c">
          <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMOajFfI_iSaNhP-_ueoQ5pVEwsj2EAAhcTaxtuOolVsQXYrrG-hiIBAAMCAAN3AAM8BA.png" alt="病耻感痛点图" />
          <span class="p1-pain-tag">痛点 03</span>
        </figure>
        <div class="p1-pain-copy">
          <h3 class="p1-pain-title">病耻感</h3>
          <p class="p1-pain-text">传统矫形器医疗器械感过强，容易让孩子在校园与社交场景中产生遮挡与抗拒心理。</p>
        </div>
      </article>
    </div>
  </section>

  <section class="p1-section p1-positioning">
    <div class="p1-rect-grid" data-section-label="技术调研">
      <article class="p1-rect-card p1-card-feature">
        <figure class="p1-feature-media p1-feature-media--cutout">
          <img loading="lazy" decoding="async" src="/portfolio/project-1/processed/tech-1-raw.png" alt="矫正功能展示图" />
        </figure>
        <div class="p1-feature-copy">
          <h2 class="p1-feature-title">矫正</h2>
          <p class="p1-feature-text">AFO 三点力学矫形，通过 F₁ 踝底、F₂ 跟骨后、F₃ 小腿前的受力关系，帮助改善足内翻步态。</p>
        </div>
      </article>

      <article class="p1-rect-card p1-card-feature">
        <figure class="p1-feature-media">
          <img loading="lazy" decoding="async" src="/portfolio/project-1/processed/tech-2-raw.png" alt="监测功能展示图" />
        </figure>
        <div class="p1-feature-copy">
          <h2 class="p1-feature-title">监测</h2>
          <p class="p1-feature-text">柔性传感面料 ThermoFit 嵌入鞋体结构，实时采集足底压力与步态变化，辅助康复判断。</p>
        </div>
      </article>

      <article class="p1-rect-card p1-card-feature">
        <figure class="p1-feature-media">
          <img loading="lazy" decoding="async" src="/portfolio/project-1/processed/tech-3-raw.png" alt="模块化连接机制展示图" />
        </figure>
        <div class="p1-feature-copy">
          <h2 class="p1-feature-title">模块化连接机制</h2>
          <p class="p1-feature-text">通过清晰的模块连接与快拆逻辑，降低穿脱门槛，让结构固定、调节与日常使用更直观高效。</p>
        </div>
      </article>
    </div>
  </section>

  <section class="p1-section p1-dev">
    <div class="p1-rect-grid">
      <article class="p1-rect-card p1-card-mapping" data-section-label="设计目标">
        <div class="p1-mapping-bg" aria-hidden="true"></div>
        <header class="p1-mapping-head">
          <p class="p1-overline">design target</p>
          <h2>从痛点到设计目标</h2>
          <p>将儿童康复中的身体问题、沟通问题与情绪问题，分别转译为结构、传感与外观策略。</p>
        </header>

        <div class="p1-mapping-list">
          <div class="p1-mapping-row">
            <span class="p1-mapping-num">01</span>
            <div class="p1-mapping-cell p1-mapping-issue">
              <small>problem</small>
              <strong>足内翻问题</strong>
            </div>
            <span class="p1-mapping-link" aria-hidden="true">→</span>
            <div class="p1-mapping-cell p1-mapping-solution">
              <small>target</small>
              <strong>AFO 三点力学矫形</strong>
            </div>
          </div>

          <div class="p1-mapping-row">
            <span class="p1-mapping-num">02</span>
            <div class="p1-mapping-cell p1-mapping-issue">
              <small>problem</small>
              <strong>沟通障碍</strong>
            </div>
            <span class="p1-mapping-link" aria-hidden="true">→</span>
            <div class="p1-mapping-cell p1-mapping-solution">
              <small>target</small>
              <strong>智能压力传感监测</strong>
            </div>
          </div>

          <div class="p1-mapping-row">
            <span class="p1-mapping-num">03</span>
            <div class="p1-mapping-cell p1-mapping-issue">
              <small>problem</small>
              <strong>病耻感</strong>
            </div>
            <span class="p1-mapping-link" aria-hidden="true">→</span>
            <div class="p1-mapping-cell p1-mapping-solution">
              <small>target</small>
              <strong>模块化运动鞋外观</strong>
            </div>
          </div>
        </div>
      </article>

      <article class="p1-rect-card p1-card-design-process" data-section-label="设计推演">
        <figure class="p1-process-figure">
          <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMVajWGPn54MjgAAeEbQ2dFd2uwuJB7AAJqEGsbQZ2oVTzhTIVSVxQ2AQADAgADdwADPAQ.png" alt="设计草图" />
          <figcaption class="p1-caption">设计草图</figcaption>
        </figure>
        <figure class="p1-process-figure">
          <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMWajWGUPZlTbiSuYv8nPCZFvTvBA4AAmsQaxtBnahVtFOl2BhV0S4BAAMCAAN3AAM8BA.png" alt="Gradient AIGC 形态探索图" />
          <figcaption class="p1-caption">AIGC 形态探索</figcaption>
        </figure>
      </article>

      <article class="p1-rect-card p1-card-making-process" data-section-label="模型制作">
        <div class="p1-making-copy">
          <p class="p1-overline">model making</p>
          <h2 class="p1-body-title">用实体草模校准鞋体体量与穿戴关系</h2>
          <p class="p1-body-text p1-body-text--large">
            通过手工模型快速验证鞋底厚度、鞋面包裹、绑带位置与模块连接关系，让形态推演从二维草图进入可触摸的穿戴尺度。
          </p>
          <p class="p1-body-text">
            过程重点放在比例修正、部件拼接与佩戴状态观察，为后续电路嵌入和最终造型提供实体依据。
          </p>
        </div>

        <div class="p1-making-gallery" aria-label="模型制作过程照片">
          <figure class="p1-making-photo p1-making-photo--hero">
            <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMXajaZtdrcYEkG3mZ8MHKPuE4XaboAAswQaxtlnrhV-2D7fyECDhABAAMCAAN3AAM8BA.png" alt="模型制作过程照片 1" />
          </figure>
          <figure class="p1-making-photo">
            <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMYajaZ2N1FbaKCCPKY0Tya5AzelyQAAs0QaxtlnrhVKmvMaEZ8VsEBAAMCAAN5AAM8BA.png" alt="模型制作过程照片 2" />
          </figure>
          <figure class="p1-making-photo">
            <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMZajaZ3RzgNzFYHUxBRfHhbyHRYnAAAs4QaxtlnrhVxOjNxcnUz4QBAAMCAAN5AAM8BA.png" alt="模型制作过程照片 3" />
          </figure>
          <figure class="p1-making-photo">
            <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMaajaZ44AOm-k9VJuMghmQss5nAlEAAs8QaxtlnrhVJDwqIfqX9lIBAAMCAAN5AAM8BA.png" alt="模型制作过程照片 4" />
          </figure>
          <figure class="p1-making-photo">
            <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMbajaZ7peVhT4fuQGXVB-uvLQf8HkAAtAQaxtlnrhVZY0y5snUNtsBAAMCAAN5AAM8BA.png" alt="模型制作过程照片 5" />
          </figure>
        </div>
      </article>

      <article class="p1-rect-card p1-card-validation-process" data-section-label="电路连接 / 代码测试">
        <section class="p1-validation-section">
          <div class="p1-validation-copy">
            <p class="p1-overline">circuit connection</p>
            <p class="p1-body-text p1-validation-text--singleline">
              通过实体连接验证传感器布点、导线走向和开发板读取链路，先保证硬件信号稳定，再进入代码测试。
            </p>
          </div>
          <div class="p1-validation-gallery p1-validation-gallery--circuit">
            <figure class="p1-validation-photo">
              <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMcajabC-c58wpx2hyQq0tzsIWp_xwAAtQQaxtlnrhVBxYnfM7QQLkBAAMCAAN5AAM8BA.png" alt="电路连接过程照片 1" />
            </figure>
            <figure class="p1-validation-photo">
              <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMdajabEAYH-MbIehxuhUqaU4SLD9oAAtUQaxtlnrhVrvNgDoika18BAAMCAAN5AAM8BA.png" alt="电路连接过程照片 2" />
            </figure>
            <figure class="p1-validation-photo">
              <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMeajabFHuqyBmH1Sm2Xc_-E0nd0TIAAtYQaxtlnrhV_BXXWkUAAV4sAQADAgADeQADPAQ.png" alt="电路连接过程照片 3" />
            </figure>
            <figure class="p1-validation-photo">
              <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMfajabGdY7294hBVNineLsc2SgCh4AAtcQaxtlnrhVXK43uJZvjEcBAAMCAAN5AAM8BA.png" alt="电路连接过程照片 4" />
            </figure>
          </div>
        </section>

        <section class="p1-validation-section p1-validation-section--code">
          <div class="p1-validation-copy">
            <p class="p1-overline">code test</p>
            <h2 class="p1-body-title">用代码读取压力变化并输出测试反馈</h2>
            <p class="p1-body-text">
              代码测试将硬件输入转译为可观察的数据变化，用手压和脚底模拟验证阈值响应是否稳定。
            </p>
          </div>
          <div class="p1-validation-code-layout">
            <div class="p1-code-block p1-code-block--screen">
              <div class="p1-code-header">
                <span class="p1-code-dot"></span>
                <span class="p1-code-dot"></span>
                <span class="p1-code-dot"></span>
                <span class="p1-code-label">Arduino — FSR pressure test</span>
              </div>
              <pre><code>const int FSR_INNER = A0;  // inner sensor
const int FSR_OUTER = A1;  // outer sensor

void setup() &#123;
  Serial.begin(9600);
&#125;

void loop() &#123;
  int innerVal = analogRead(FSR_INNER);
  int outerVal = analogRead(FSR_OUTER);

  if ((innerVal - outerVal) &gt; 350) &#123;
    triggerAlert();
  &#125;

  delay(50);
&#125;</code></pre>
            </div>
            <div class="p1-validation-gallery p1-validation-gallery--code">
              <figure class="p1-validation-photo">
                <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMgajabcxem948a8XviF74iI_IOM44AAtgQaxtlnrhVRHpGKC9n8ggBAAMCAAN5AAM8BA.png" alt="代码测试过程照片 1" />
              </figure>
              <figure class="p1-validation-photo">
                <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMhajabd3ZCUjwSoqdRVNR_KoXZngkAAtkQaxtlnrhVPwETneTw7uEBAAMCAAN5AAM8BA.png" alt="代码测试过程照片 2" />
              </figure>
              <figure class="p1-validation-photo">
                <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMiajabesFP0qeANZiFquqxeXqTKzkAAtoQaxtlnrhV9CHH1EN136cBAAMCAAN5AAM8BA.png" alt="代码测试过程照片 3" />
              </figure>
              <figure class="p1-validation-photo">
                <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMjajabgdAQt3xYZCTo6bRpYU-eYkkAAtsQaxtlnrhV756pLVW-yk8BAAMCAAN5AAM8BA.png" alt="代码测试过程照片 4" />
              </figure>
            </div>
          </div>
        </section>
      </article>
    </div>
  </section>

  <section class="p1-section p1-final">
    <div class="p1-rect-grid">
      <article class="p1-rect-card p1-card-render-gallery" data-section-label="产品渲染">
        <section class="p1-render-screen p1-render-screen--modular">
          <figure class="p1-render-item p1-render-item--full">
            <img loading="lazy" decoding="async" src="/portfolio/project-1/renders/modular.png" alt="模块化产品渲染图" />
          </figure>
        </section>

        <section class="p1-render-screen p1-render-screen--details">
          <figure class="p1-render-item">
            <img loading="lazy" decoding="async" src="/portfolio/project-1/renders/detail-strap.png" alt="可调节绑带细节渲染图" />
          </figure>
          <figure class="p1-render-item">
            <img loading="lazy" decoding="async" src="/portfolio/project-1/renders/detail-buckle.png" alt="蓝粉卡扣渐变细节渲染图" />
          </figure>
          <figure class="p1-render-item">
            <img loading="lazy" decoding="async" src="/portfolio/project-1/renders/detail-mesh.png" alt="透气网面细节渲染图" />
          </figure>
          <figure class="p1-render-item p1-render-item--overall">
            <img loading="lazy" decoding="async" src="/portfolio/project-1/renders/overall-1.png" alt="产品整体渲染图 1" />
          </figure>
        </section>

        <section class="p1-render-screen p1-render-screen--exploded">
          <div class="p1-exploded-stage" data-exploded-stage>
            <div class="p1-exploded-media" data-exploded-media>
              <video
