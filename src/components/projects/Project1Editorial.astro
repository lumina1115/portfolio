  .p1-lab-sketch-figure {
    overflow: visible;
    border-radius: 0;
    background: transparent;
    box-shadow: 0 1.6rem 4rem rgba(var(--p1-accent-rgb), 0.09);
  }

  .p1-lab-sketch-figure img,
  .p1-aigc-tile img,
  .p1-circuit-photo img {
    width: 100%;
    height: 100%;
    border-radius: 12px;
    object-fit: cover;
    background: transparent;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1), filter 0.7s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .p1-lab-sketch-figure img {
    height: auto;
    border-radius: 0;
    object-fit: contain;
  }

  .p1-aigc-board {
    --spot-x: 50%;
    --spot-y: 50%;
    position: relative;
    min-height: min(66vh, 42rem);
    display: grid;
    place-items: center;
    overflow: hidden;
    padding: clamp(1rem, 2.5vw, 2rem);
    isolation: isolate;
    background:
      radial-gradient(circle at 50% 50%, rgba(var(--p1-accent-rgb), 0.055), transparent 46%),
      rgba(247, 245, 240, 0.82);
  }

  .p1-aigc-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url('https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAM5ajjfXXIoSQObFQMRCY4Ed5tgtiwAAgoRaxsof8lVSQEkf8NyUm4BAAMCAAN5AAM8BA.png');
    background-size: auto 100%;
    background-position: center;
    background-repeat: repeat-x;
    pointer-events: none;
  }

  .p1-aigc-bg--base {
    opacity: 0.075;
    filter: grayscale(100%) blur(1px);
  }

  .p1-aigc-bg--spotlight {
    opacity: 0;
    filter: grayscale(0%) blur(0);
    -webkit-mask-image: radial-gradient(
      circle at var(--spot-x) var(--spot-y),
      #000 0,
      rgba(0, 0, 0, 0.92) clamp(5.2rem, 10vw, 8.4rem),
      rgba(0, 0, 0, 0.42) clamp(6.8rem, 13vw, 10.8rem),
      transparent clamp(8.4rem, 16vw, 13rem)
    );
    mask-image: radial-gradient(
      circle at var(--spot-x) var(--spot-y),
      #000 0,
      rgba(0, 0, 0, 0.92) clamp(5.2rem, 10vw, 8.4rem),
      rgba(0, 0, 0, 0.42) clamp(6.8rem, 13vw, 10.8rem),
      transparent clamp(8.4rem, 16vw, 13rem)
    );
    transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1), filter 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .p1-aigc-board.is-spotlight-active .p1-aigc-bg--spotlight {
    opacity: 0.16;
  }

  .p1-aigc-tiles {
    position: relative;
    z-index: 1;
    width: min(100%, 50rem);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: repeat(2, minmax(0, 1fr));
    gap: clamp(0.7rem, 1.7vw, 1.35rem);
  }

  .p1-aigc-tile {
    --shoe-x: 0px;
    --shoe-y: 0px;
    aspect-ratio: 1 / 1;
    display: grid;
    place-items: center;
    overflow: hidden;
