    border-radius: 12px;
    background: transparent;
    box-shadow: none;
    transition:
      transform 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .p1-aigc-tile img {
    width: 92%;
    height: 92%;
    border-radius: 0;
    object-fit: contain;
    object-position: center;
    background: transparent;
    filter: grayscale(100%) saturate(0.35) contrast(0.9) opacity(0.42) drop-shadow(0 1rem 1.4rem rgba(26, 26, 26, 0.06));
    mix-blend-mode: multiply;
    transform: translate3d(var(--shoe-x), var(--shoe-y), 0);
  }

  .p1-aigc-tile:hover,
  .p1-aigc-tile.is-active {
    z-index: 2;
    transform: translateY(-4px);
    border-color: rgba(91, 174, 235, 0.82);
    background: rgba(247, 250, 252, 0.92) !important;
    box-shadow:
      0 0 0 1px rgba(91, 174, 235, 0.16),
      0 0.9rem 2.2rem rgba(var(--p1-accent-rgb), 0.16),
      inset 0 0 0 1px rgba(255, 255, 255, 0.72);
  }

  .p1-aigc-tile:hover img,
  .p1-aigc-tile.is-active img {
    background: transparent !important;
    filter: grayscale(0%) saturate(1.04) contrast(1.01) opacity(1) drop-shadow(0 1.2rem 1.9rem rgba(var(--p1-accent-rgb), 0.18));
    mix-blend-mode: normal;
  }

  .p1-lab-circuit {
    --circuit-photo-height: min(68vh, 38rem);
    overflow: visible;
    gap: var(--circuit-module-gap);
    max-width: 100%;
    min-width: 0;
  }

  .p1-lab-copy--circuit span {
    color: rgba(var(--p1-accent-rgb), 0.72);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .p1-lab-copy--circuit h3 {
    max-width: 38rem;
  }

  .p1-circuit-scroll-shell {
    position: relative;
    min-height: var(--circuit-photo-height);
    width: 100%;
    max-width: 100%;
    margin-inline: 0;
    overflow: hidden;
    isolation: isolate;
  }

  .p1-circuit-sticky {
    position: relative;
    top: 0;
    height: var(--circuit-photo-height);
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-inline: 0;
    max-width: 100%;
  }

  .p1-circuit-sticky.is-fixed {
    position: fixed;
    top: 0;
    right: auto;
    bottom: auto;
    z-index: 18;
  }

  .p1-circuit-sticky.is-after {
    position: absolute;
    inset: auto 0 0 0;
    width: 100% !important;
  }

  .p1-circuit-viewport {
    position: relative;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
    border-radius: 6px;
    contain: layout paint;
    clip-path: inset(0 round 6px);
  }

  .p1-circuit-track {
    display: flex;
    gap: 12px;
    width: max-content;
    will-change: transform;
    transition: none;
  }

  .p1-circuit-photo {
