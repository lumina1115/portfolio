  .p1-card-code-sandbox.is-visible .p1-code-line {
    animation: p1-code-type-line 0.48s steps(34, end) both;
    animation-delay: calc(0.12s + var(--line) * 72ms);
  }

  .tok-key {
    color: #005bd8;
    font-weight: 700;
  }

  .tok-type {
    color: #244e68;
    font-weight: 650;
  }

  .tok-fn {
    color: #9a5a13;
    font-weight: 650;
  }

  .tok-comment {
    color: rgba(77, 86, 98, 0.68);
    font-weight: 500;
  }

  .tok-string {
    color: #7a5c12;
    font-weight: 600;
  }

  .p1-code-cursor {
    display: inline-block;
    width: 0.52em;
    height: 1.2em;
    margin-left: 0.18em;
    vertical-align: -0.18em;
    border-radius: 1px;
    background: #0066ff;
    opacity: 0;
  }

  .p1-card-code-sandbox.is-visible .p1-code-cursor {
    opacity: 1;
    animation: p1-code-cursor-blink 1s steps(1, end) infinite;
    animation-delay: 2.8s;
  }

  .p1-code-line--serial {
    position: relative;
  }

  .p1-data-spill {
    display: inline-flex;
    align-items: center;
    gap: 0.22rem;
    margin-left: 0.55rem;
    padding: 0.08rem 0.34rem 0.09rem;
    border-radius: 999px;
    border: 1px solid rgba(0, 102, 255, 0.18);
    background: rgba(0, 102, 255, 0.08);
    color: rgba(0, 102, 255, 0.78);
    font-family: 'Fira Code', 'SF Mono', 'Cascadia Code', Consolas, monospace;
    font-size: 0.64rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0;
    opacity: 0;
    transform: translateX(-0.25rem);
    transition:
      opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
