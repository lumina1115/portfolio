    transition: box-shadow 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .p1-circuit-photo img {
    border-radius: 6px;
    transition: transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .p1-circuit-photo:hover {
    box-shadow: 0 1.6rem 3.4rem rgba(var(--p1-accent-rgb), 0.16);
    z-index: 1;
  }

  .p1-circuit-photo:hover img {
    transform: scale(1.018);
  }

  .p1-card-code-sandbox {
    height: min(100svh, 56rem);
    min-height: 0;
    max-height: 100svh;
    padding: clamp(1.5rem, 2.6vw, 2.6rem) clamp(1.5rem, 2.6vw, 2.6rem) var(--chapter-end-media-gap);
    overflow: hidden;
    isolation: isolate;
    color: #2a2d34;
    border: 1px solid rgba(226, 228, 233, 0.8);
    background:
      radial-gradient(circle at 78% 16%, rgba(0, 102, 255, 0.075), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.35), rgba(241, 238, 227, 0.82)),
      #f1eee3;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.85),
      0 1.4rem 3rem rgba(var(--p1-accent-rgb), 0.08);
