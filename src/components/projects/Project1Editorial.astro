    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-transform: uppercase;
    color: rgba(var(--p1-accent-rgb), 0.74);
  }

  .p1-sandbox-head h2 {
    margin: 0;
    color: #2a2d34;
    font-family: var(--font-cjk-sans);
