  .p1-card-code-sandbox.is-visible .p1-sandbox-panel {
    opacity: 1;
    transform: translateY(0);
  }

  .p1-card-code-sandbox.is-visible .p1-sensor-panel {
    transition-delay: 0.12s;
  }

  .p1-code-editor {
    overflow: hidden;
    min-height: 0;
    background: rgba(245, 246, 248, 0.75);
  }

  .p1-code-editor .p1-code-header {
    gap: 0.5rem;
    padding: 0.62rem 0.9rem;
    border-bottom: 1px solid rgba(226, 228, 233, 0.8);
    background: rgba(255, 255, 255, 0.48);
    box-shadow: none;
  }

  .p1-code-editor .p1-code-label {
    color: rgba(42, 45, 52, 0.66);
  }

  .p1-code-editor .p1-code-dot {
    background: #f2a7ae;
  }

  .p1-code-editor .p1-code-dot:nth-child(2) {
    background: #e9c67a;
  }

  .p1-code-editor .p1-code-dot:nth-child(3) {
    background: #9bc7b1;
  }

  .p1-code-state {
    margin-left: auto;
    color: rgba(0, 102, 255, 0.72);
    font-family: var(--font-sans);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .p1-code-editor pre {
    margin: 0;
    height: calc(100% - 2.35rem);
    min-height: 0;
    overflow: hidden;
    padding: clamp(0.62rem, 0.95vw, 0.9rem) clamp(0.78rem, 1.1vw, 1rem);
    font-family: 'Fira Code', 'SF Mono', 'Cascadia Code', Consolas, monospace;
    font-size: clamp(0.7rem, 0.78vw, 0.86rem);
    font-weight: 520;
    line-height: 0.78;
    color: #1f2933;
    font-variant-numeric: tabular-nums;
  }

  .p1-code-line {
    display: block;
    width: max-content;
