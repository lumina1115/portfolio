  .p1-sensor-photo img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
    transform: scale(1.03);
    filter: saturate(0.82) contrast(1.04);
  }

  .p1-waveform-card {
