<script>
  const setupExplodedVideo = () => {
    const stage = document.querySelector('[data-exploded-stage]');
    const media = document.querySelector('[data-exploded-media]');
    const video = document.querySelector('[data-exploded-video]');
    const layer = document.querySelector('[data-exploded-layer]');

    const screen = stage.closest('.p1-render-screen--exploded');

    if (!(stage instanceof HTMLElement) || !(media instanceof HTMLElement) || !(video instanceof HTMLVideoElement) || !(layer instanceof HTMLElement) || !(screen instanceof HTMLElement)) {
      return;
    }

    const syncAnnotationLayer = () => {
      const mediaRect = media.getBoundingClientRect();
      const videoRatio = video.videoWidth && video.videoHeight ? video.videoWidth / video.videoHeight : 16 / 9;
      const mediaRatio = mediaRect.width / mediaRect.height;

      let width = mediaRect.width;
      let height = mediaRect.height;
      let left = 0;
      let top = 0;

      if (mediaRatio > videoRatio) {
        width = mediaRect.height * videoRatio;
        left = (mediaRect.width - width) / 2;
      } else {
        height = mediaRect.width / videoRatio;
        top = (mediaRect.height - height) / 2;
      }

      layer.style.left = `${left}px`;
      layer.style.top = `${top}px`;
      layer.style.width = `${width}px`;
      layer.style.height = `${height}px`;

      const screenRect = screen.getBoundingClientRect();
      screen.style.setProperty('--exploded-frame-top', `${mediaRect.top - screenRect.top + top}px`);
      screen.style.setProperty('--exploded-frame-height', `${height}px`);
    };

    const revealAnnotations = () => {
      window.setTimeout(() => {
        stage.classList.add('is-annotated');
      }, 300);
    };

    video.muted = true;
    video.loop = false;
    video.playsInline = true;
    video.pause();

    let hasStarted = false;

    const finishOnFinalFrame = () => {
      video.pause();
      revealAnnotations();
    };

    const playOnce = () => {
      if (hasStarted) {
        return;
      }

      hasStarted = true;
      stage.classList.remove('is-video-paused');
      stage.classList.remove('is-annotated');

      if (video.ended || video.currentTime > 0.05) {
        try {
          video.currentTime = 0;
        } catch {
          // If the browser refuses an immediate seek, playback can still continue from the current frame.
        }
      }

      const playPromise = video.play();
      if (playPromise) {
        playPromise.catch(() => {
          hasStarted = false;
          stage.classList.add('is-video-paused');
        });
      }
    };

    video.addEventListener('loadedmetadata', () => {
      syncAnnotationLayer();
    });

    video.addEventListener('ended', finishOnFinalFrame, { once: true });

    window.addEventListener('resize', syncAnnotationLayer);
    syncAnnotationLayer();

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        const entry = entries[0];
        if (entry?.isIntersecting && entry.intersectionRatio >= 0.45) {
          playOnce();
          observer.disconnect();
        }
      }, {
        threshold: [0, 0.25, 0.45, 0.65],
      });

      observer.observe(stage);
    } else {
      playOnce();
    }
  };

  const setupChapterSidebar = () => {
    const chapters = Array.from(document.querySelectorAll('[data-chapter-section]'));

    if (!chapters.length) {
      return;
    }

    const activateChapter = (chapter: Element) => {
      chapters.forEach((item) => {
        item.classList.toggle('is-active', item === chapter);
      });
    };

    activateChapter(chapters[0]);

    if (!('IntersectionObserver' in window)) {
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      const visibleEntries = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio);

      if (visibleEntries[0]?.target) {
        activateChapter(visibleEntries[0].target);
      }
    }, {
      rootMargin: '-28% 0px -42% 0px',
      threshold: [0, 0.12, 0.28, 0.5, 0.72],
    });

    chapters.forEach((chapter) => observer.observe(chapter));
  };

  const setupRailMenuVisibility = () => {
    const chapters = Array.from(document.querySelectorAll('[data-chapter-section]'));
    const firstChapter = chapters[0];
    const lastChapter = chapters[chapters.length - 1];

    if (!(firstChapter instanceof HTMLElement) || !(lastChapter instanceof HTMLElement)) {
      return;
    }

    const setVisible = (isVisible: boolean) => {
      document.body.classList.toggle('menu-on-rail', isVisible);
    };

    let ticking = false;

    const updateVisibility = () => {
      const stickyOffset = window.innerHeight * 0.12;
      const firstTop = firstChapter.getBoundingClientRect().top + window.scrollY;
      const lastBottom = lastChapter.getBoundingClientRect().bottom + window.scrollY;
      const scrollAnchor = window.scrollY + stickyOffset;

      setVisible(scrollAnchor >= firstTop && window.scrollY < lastBottom);
      ticking = false;
    };

    const requestUpdate = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateVisibility);
        ticking = true;
      }
    };

    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
    updateVisibility();
  };

  const setupTargetMappingReveal = () => {
    // Reveals the three mapping rows once, with a 0.2s stagger between cards.
    const mapping = document.querySelector('[data-target-map]');
    const cards = Array.from(document.querySelectorAll('[data-target-card]'));

    if (!(mapping instanceof HTMLElement) || !cards.length) {
      return;
    }

    if (!('IntersectionObserver' in window)) {
      cards.forEach((card) => card.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      const entry = entries[0];

      if (!entry?.isIntersecting) {
        return;
      }

      cards.forEach((card, index) => {
        window.setTimeout(() => {
          card.classList.add('is-visible');
        }, index * 200);
      });
      observer.disconnect();
    }, {
      rootMargin: '0px 0px -18% 0px',
      threshold: 0.18,
    });

    observer.observe(mapping);
  };

  const setupLabInteractions = () => {
    const sketch = document.querySelector('[data-sketch-reveal]');
    const circuitSection = document.querySelector('[data-circuit-scroll]');
    const circuitShell = document.querySelector('[data-circuit-shell]');
    const circuitSticky = document.querySelector('[data-circuit-sticky]');
    const circuitViewport = document.querySelector('[data-circuit-viewport]');
    const circuitTrack = document.querySelector('[data-circuit-track]');
    const aigcSpotlight = document.querySelector('[data-aigc-spotlight]');
    const codeSandbox = document.querySelector('[data-code-sandbox]');

    if (sketch instanceof HTMLElement) {
      if ('IntersectionObserver' in window) {
        const sketchObserver = new IntersectionObserver((entries) => {
          if (entries[0]?.isIntersecting) {
            sketch.classList.add('is-visible');
            sketchObserver.disconnect();
          }
        }, {
          rootMargin: '0px 0px -18% 0px',
          threshold: 0.18,
        });

        sketchObserver.observe(sketch);
      } else {
        sketch.classList.add('is-visible');
      }
    }

    if (aigcSpotlight instanceof HTMLElement) {
      const tiles = Array.from(aigcSpotlight.querySelectorAll('.p1-aigc-tile'));

      tiles.forEach((tile) => {
        if (!(tile instanceof HTMLElement)) {
          return;
        }

        const resetTile = () => {
          tile.style.setProperty('--shoe-x', '0px');
          tile.style.setProperty('--shoe-y', '0px');
          tile.classList.remove('is-active');
        };

        tile.addEventListener('pointermove', (event) => {
          const boardRect = aigcSpotlight.getBoundingClientRect();
          const tileRect = tile.getBoundingClientRect();
          const relX = (event.clientX - tileRect.left) / tileRect.width - 0.5;
          const relY = (event.clientY - tileRect.top) / tileRect.height - 0.5;
          const spotX = ((event.clientX - boardRect.left) / boardRect.width) * 100;
          const spotY = ((event.clientY - boardRect.top) / boardRect.height) * 100;

          aigcSpotlight.style.setProperty('--spot-x', `${spotX}%`);
          aigcSpotlight.style.setProperty('--spot-y', `${spotY}%`);
          tile.style.setProperty('--shoe-x', `${(-relX * 10).toFixed(2)}px`);
          tile.style.setProperty('--shoe-y', `${(-relY * 10).toFixed(2)}px`);
        });

        tile.addEventListener('pointerenter', () => {
          tile.classList.add('is-active');
        });
        tile.addEventListener('pointerleave', () => {
          resetTile();
        });
      });
    }

    if (codeSandbox instanceof HTMLElement) {
      if ('IntersectionObserver' in window) {
        const sandboxObserver = new IntersectionObserver((entries) => {
          if (entries[0]?.isIntersecting) {
            codeSandbox.classList.add('is-visible');
            sandboxObserver.disconnect();
          }
        }, {
          rootMargin: '0px 0px -16% 0px',
          threshold: 0.22,
        });

        sandboxObserver.observe(codeSandbox);
      } else {
        codeSandbox.classList.add('is-visible');
      }

      if (!codeSandbox.dataset.plotterReady) {
        codeSandbox.dataset.plotterReady = 'true';

        const waveCurrent = codeSandbox.querySelector('[data-wave-current]');
        const wavePeak = codeSandbox.querySelector('[data-wave-peak]');
        const currentValue = codeSandbox.querySelector('[data-signal-current]');
        const peakValue = codeSandbox.querySelector('[data-signal-peak]');
        const spillValue = codeSandbox.querySelector('[data-spill-value]');
        const spillTag = codeSandbox.querySelector('.p1-data-spill');

        if (waveCurrent && wavePeak && currentValue && peakValue && spillValue) {
          const sampleCount = 360;
          const cycleLength = 112;
          const values = Array.from({ length: sampleCount }, () => 0);
          const envelope = Array.from({ length: sampleCount }, () => 0);
          let sampleIndex = 0;
          let cyclePeak = 0;
          let previousPhase = 0;
          let smoothValue = 0;

          const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);
          const easeOut = (value: number) => 1 - Math.pow(1 - value, 3);
          const easeIn = (value: number) => value * value * value;

          const gaitValue = (index: number) => {
            const phase = ((index % cycleLength) + cycleLength) % cycleLength / cycleLength;
            let value = 0;

            if (phase < 0.14) {
              value = 18 + Math.sin(phase / 0.14 * Math.PI) * 18;
            } else if (phase < 0.27) {
              value = 40 + easeOut((phase - 0.14) / 0.13) * 760;
            } else if (phase < 0.56) {
              const t = (phase - 0.27) / 0.29;
              value = 780 - easeOut(t) * 420 + Math.sin(t * Math.PI * 2) * 26;
            } else if (phase < 0.74) {
              const t = (phase - 0.56) / 0.18;
              value = 330 + Math.sin(t * Math.PI) * 260;
            } else {
              const t = (phase - 0.74) / 0.26;
              value = 310 * (1 - easeIn(t)) + 16;
            }

            const microVariation = Math.sin(index * 0.41) * 14 + Math.sin(index * 0.097) * 9;
            return Math.round(clamp(value + microVariation, 0, 1023));
          };

          const yFromValue = (value: number) => 162 - value / 1023 * 136;
          const buildPath = (items: number[]) => items
            .map((value, index) => `${index === 0 ? 'M' : 'L'}${index} ${yFromValue(value).toFixed(1)}`)
            .join(' ');
          const formatValue = (value: number) => String(value).padStart(3, '0');

          const tickPlotter = () => {
            const raw = gaitValue(sampleIndex);
            const phase = ((sampleIndex % cycleLength) + cycleLength) % cycleLength / cycleLength;

            if (phase < previousPhase) {
              cyclePeak = 0;
            }

            cyclePeak = Math.max(cyclePeak, raw);
            previousPhase = phase;
            smoothValue = Math.round(smoothValue * 0.82 + raw * 0.18);

            values.push(raw);
            values.shift();
            envelope.push(smoothValue);
            envelope.shift();

            waveCurrent.setAttribute('d', buildPath(values));
            wavePeak.setAttribute('d', buildPath(envelope));

            currentValue.textContent = formatValue(raw);
            peakValue.textContent = formatValue(cyclePeak);
            spillValue.textContent = formatValue(raw);

            spillTag?.classList.toggle('is-hot', raw > 620);
            sampleIndex += 1;
          };

          for (let index = 0; index < sampleCount; index += 1) {
            tickPlotter();
          }

          window.setInterval(tickPlotter, 20);
        }
      }
    }

    if (
      !(circuitSection instanceof HTMLElement) ||
      !(circuitShell instanceof HTMLElement) ||
      !(circuitSticky instanceof HTMLElement) ||
      !(circuitViewport instanceof HTMLElement) ||
      !(circuitTrack instanceof HTMLElement)
    ) {
      return;
    }

    let ticking = false;
    let circuitPointerActive = false;
    let circuitShift = 0;
    let circuitMaxShift = 0;

    const updateCircuitScroll = () => {
      const photos = Array.from(circuitTrack.children).filter((child): child is HTMLElement => child instanceof HTMLElement);
      const trackStyle = window.getComputedStyle(circuitTrack);
      const trackGap = Number.parseFloat(trackStyle.columnGap || trackStyle.gap || '0') || 0;
      const sectionRect = circuitSection.getBoundingClientRect();
      const visibleWidth = Math.max(sectionRect.width, 1);
      const photoWidthRatio = window.matchMedia('(max-width: 768px)').matches ? 0.82 : window.matchMedia('(max-width: 1100px)').matches ? 0.78 : 0.68;
      const minPhotoWidth = Math.min(visibleWidth * 0.88, 260);
      const photoWidth = Math.max(Math.min(visibleWidth * photoWidthRatio, 704), minPhotoWidth);

      circuitViewport.style.setProperty('--circuit-photo-width', `${photoWidth}px`);
      circuitViewport.style.width = `${visibleWidth}px`;

      // Force the browser to apply the freshly calculated image width before measuring the track.
      circuitTrack.getBoundingClientRect();
      const measuredTrackWidth = photos.reduce((total, photo) => total + photo.offsetWidth, 0) + Math.max(photos.length - 1, 0) * trackGap;
      const trackWidth = Math.max(circuitTrack.scrollWidth, measuredTrackWidth);
      const maxShift = Math.max(trackWidth - visibleWidth, 0);

      const stickyHeight = Math.max(circuitSticky.offsetHeight, circuitViewport.offsetHeight, 1);
      circuitShell.style.height = `${Math.ceil(stickyHeight)}px`;
      circuitMaxShift = maxShift;
      circuitShift = Math.min(circuitShift, circuitMaxShift);

      circuitTrack.style.transform = `translate3d(${-circuitShift}px, 0, 0)`;
      circuitSticky.classList.remove('is-fixed', 'is-after');
      circuitSticky.style.left = '';
      circuitSticky.style.width = '';

      ticking = false;
    };

    const requestUpdate = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateCircuitScroll);
        ticking = true;
      }
    };

    const setCircuitPointerActive = (active: boolean) => {
      circuitPointerActive = active;
      requestUpdate();
    };

    const handleCircuitWheel = (event: WheelEvent) => {
      if (!circuitPointerActive || circuitMaxShift <= 0) {
        return;
      }

      const delta = Math.abs(event.deltaX) > Math.abs(event.deltaY) ? event.deltaX : event.deltaY;
      const nextShift = Math.min(Math.max(circuitShift + delta, 0), circuitMaxShift);
      const canMove = nextShift !== circuitShift;

      if (!canMove) {
        return;
      }

      event.preventDefault();
      circuitShift = nextShift;
      circuitTrack.style.transform = `translate3d(${-circuitShift}px, 0, 0)`;
    };

    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
    circuitViewport.addEventListener('pointerenter', () => setCircuitPointerActive(true));
    circuitViewport.addEventListener('pointerleave', () => setCircuitPointerActive(false));
    circuitViewport.addEventListener('pointerdown', () => setCircuitPointerActive(true));
    circuitViewport.addEventListener('wheel', handleCircuitWheel, { passive: false });
    circuitTrack.querySelectorAll('img').forEach((image) => {
      image.addEventListener('load', requestUpdate, { once: true });
    });
    updateCircuitScroll();
  };

  const setupRenderGalleryInteractions = () => {
    const modularReveal = document.querySelector('[data-modular-reveal]');
    const revealItems = Array.from(document.querySelectorAll('[data-render-reveal]'));
    const tiltItems = Array.from(document.querySelectorAll('[data-render-tilt]'));
    let modularTicking = false;

    const updateModularReveal = () => {
      if (!(modularReveal instanceof HTMLElement)) {
        modularTicking = false;
        return;
      }

      const rect = modularReveal.getBoundingClientRect();
      const scrollable = Math.max(1, rect.height - window.innerHeight);
      const progress = Math.min(1, Math.max(0, -rect.top / scrollable));
      const easedProgress = 1 - Math.pow(1 - progress, 3);
      const scale = 1.05 - easedProgress * 0.05;

      modularReveal.style.setProperty('--modular-reveal', easedProgress.toFixed(4));
      modularReveal.style.setProperty('--modular-scale', scale.toFixed(4));
      modularTicking = false;
    };

    const requestModularReveal = () => {
      if (!modularTicking) {
        window.requestAnimationFrame(updateModularReveal);
        modularTicking = true;
      }
    };

    if (modularReveal instanceof HTMLElement) {
      window.addEventListener('scroll', requestModularReveal, { passive: true });
      window.addEventListener('resize', requestModularReveal);
      modularReveal.querySelectorAll('img').forEach((image) => {
        image.addEventListener('load', requestModularReveal, { once: true });
      });
      updateModularReveal();
    }

    if (revealItems.length) {
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, {
          rootMargin: '0px 0px -14% 0px',
          threshold: 0.18,
        });

        revealItems.forEach((item) => observer.observe(item));
      } else {
        revealItems.forEach((item) => item.classList.add('is-visible'));
      }
    }

    tiltItems.forEach((item) => {
      if (!(item instanceof HTMLElement)) {
        return;
      }

      item.addEventListener('pointermove', (event) => {
        const rect = item.getBoundingClientRect();
        const x = (event.clientX - rect.left) / rect.width - 0.5;
        const y = (event.clientY - rect.top) / rect.height - 0.5;
        const rotateX = (-y * 10).toFixed(2);
        const rotateY = (x * 10).toFixed(2);

        item.style.setProperty('--rx', `${rotateX}deg`);
        item.style.setProperty('--ry', `${rotateY}deg`);
        item.style.setProperty('--shine-x', `${(x + 0.5) * 100}%`);
      });

      item.addEventListener('pointerleave', () => {
        item.style.setProperty('--rx', '0deg');
        item.style.setProperty('--ry', '0deg');
        item.style.setProperty('--shine-x', '50%');
      });
    });
  };

  const setupProject1Interactions = () => {
    setupExplodedVideo();
    setupChapterSidebar();
    setupRailMenuVisibility();
    setupTargetMappingReveal();
    setupLabInteractions();
    setupRenderGalleryInteractions();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupProject1Interactions, { once: true });
  } else {
    setupProject1Interactions();
  }
</script>

