    text-transform: uppercase;
    color: rgba(var(--p1-accent-rgb), 0.72);
  }

  .p1-lab-head h2,
  .p1-lab-copy h3 {
    margin: 0;
    color: var(--p1-accent);
    font-family: var(--font-cjk-sans);
    font-weight: 800;
    letter-spacing: 0;
  }

  .p1-lab-head h2 {
    font-size: clamp(2rem, 4vw, 4rem);
    line-height: 1.05;
  }

  .p1-lab-head p:last-child {
