    background: rgba(0, 102, 255, 0.14);
  }

  .p1-data-spill b {
    min-width: 3ch;
    font: inherit;
    text-align: right;
  }

  .p1-sensor-panel {
    display: grid;
    grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
