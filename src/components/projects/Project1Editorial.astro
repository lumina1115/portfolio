---
const cdnBase = 'https://portfolio-image-cdn.zongxz66.workers.dev';
const { project } = Astro.props as { project: any };
const heroTitle = project.data.title?.split(' — ')[0] ?? project.data.title;
const heroSubtitle = project.data.subtitle ?? project.data.title?.split(' — ')[1] ?? '';
const heroSummary = project.data.summary;

// 标注坐标调节说明：
// anchor 是箭头指向产品结构的位置，label 是文字卡片的位置。
// x / y 都是相对于“视频真实画面”的百分比坐标：x=0 在最左，x=100 在最右；y=0 在最上，y=100 在最下。
// 例如想把文字往右移，就增加 label.x；想把箭头指向点往下移，就增加 anchor.y。
const explodedAnnotations = [
  {
    id: 'side-support',
    title: '硬质硅胶外壳',
    text: '高强度树脂材料，提供踝关节稳固支撑',
    anchor: { x: 35, y: 65 },
    label: { x: 8, y: 65 },
  },
  {
    id: 'adjust-system',
    title: '紧固绑带',
    text: '多点位快速调节设计，适应不同脚部维度需求',
    anchor: { x: 58, y: 60 },
    label: { x: 78, y: 26 },
  },
  {
    id: 'base',
    title: '模块化鞋底',
    text: '流线型设计增强运动时尚感',
    anchor: { x: 51, y: 87 },
    label: { x: 78, y: 80 },
  },
  {
    id: 'inner-fabric',
    title: '柔软内衬',
    text: '内置传感面料 ThermorFit，实时监测步态与足底压力',
    anchor: { x: 25, y: 40 },
    label: { x: 8, y: 30 },
  },
];
---

<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" />

<main class="p1-root">
  <section class="p1-hero">
    <div class="p1-hero-shell">
      <div class="p1-hero-media" aria-hidden="true">
        <img loading="lazy" decoding="async"
          src={`${cdnBase}/project-1/cover.jpg`}
          alt=""
          class="p1-hero-img"
        />
      </div>

      <div class="p1-hero-copy">
        <p class="p1-caption p1-hero-caption">01 · Case Study</p>

        <div class="p1-copy-stack">
          <h1 class="p1-hero-title">{heroTitle}</h1>
        </div>

        <p class="p1-hero-desc" aria-label={heroSummary}>
          <span>Gradient 是一款面向痉挛型脑瘫儿童的智能踝足矫形器</span>
          <span>通过 AFO 三点力学结构矫正足内翻步态，内置柔性压力传感面料</span>
          <span>实时监测足底数据，帮助医生与家长掌握康复进程</span>
        </p>

        <p class="p1-hero-quote">让康复，始于每一步</p>

        <div class="p1-hero-tags">
          <span>AFO 三点力学矫形</span>
          <span>柔性压力传感监测</span>
          <span>模块化磁吸快穿脱</span>
        </div>
      </div>
    </div>
  </section>

  <section class="p1-section p1-chapter p1-chapter--insight is-active" id="p1-insight" data-chapter-section data-chapter="insight">
    <div class="p1-editorial-track">
      <aside class="p1-sticky-rail">
        <a href="#p1-insight" class="p1-sticky-tag" data-chapter-link>
          <span class="p1-sidebar-rule" aria-hidden="true"></span>
          <span class="p1-sidebar-copy">
            <span class="p1-sidebar-index">01</span>
            <span class="p1-sidebar-title">
              <span>INSIGHT</span>
              <span>&amp;</span>
              <span>RESEARCH</span>
            </span>
            <span class="p1-sidebar-subtitle">用户洞察与需求分析</span>
          </span>
        </a>
      </aside>
      <div class="p1-section-main">
    <section class="p1-chapter-block p1-context">
    <div class="p1-rect-grid p1-rect-grid--context">
      <article class="p1-rect-card p1-card-context-merged" data-section-label="设计背景">
        <div class="p1-context-copy-panel">
          <p class="p1-context-title">痉挛性脑性瘫痪发病率高，步态问题突出。</p>
        </div>

        <div class="p1-context-detail-panel">
          <p class="p1-context-body">
            痉挛性脑瘫是儿童高发的运动障碍疾病，足部肌张力紊乱常引发<span class="p1-context-key">足内翻</span>，造成重心偏移、步态不稳与更高跌倒风险。与此同时，患儿往往难以准确表达疼痛与不适，传统矫形器又普遍<span class="p1-context-key">外观医疗化</span>，容易带来<span class="p1-context-key">病耻感与穿戴抗拒</span>。市场仍缺少兼顾步态数据采集、医患沟通与儿童审美的智能矫形设备。
          </p>

          <div class="p1-stat-rail">
            <div class="p1-stat">
              <span class="p1-stat-note">每千名活产婴儿脑瘫发病率</span>
              <div class="p1-stat-row">
                <span class="p1-stat-num">2–3.4</span>
                <span class="p1-stat-unit">例</span>
              </div>
            </div>
            <div class="p1-stat">
              <span class="p1-stat-note">其中痉挛型占比</span>
              <div class="p1-stat-row">
                <span class="p1-stat-num">75</span>
                <span class="p1-stat-unit">%</span>
              </div>
            </div>
          </div>
        </div>

        <figure class="p1-context-media">
          <img loading="lazy" decoding="async"
            src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMHajEen4wRm27yrMh7iw4AAfFaq-A2AALqEWsbbjqJVbS5QfLRy_q0AQADAgADdwADPAQ.png"
            alt="背景调研图"
          />
        </figure>
      </article>
    </div>
    </section>

    <section class="p1-chapter-block p1-pain">
    <div class="p1-pain-grid" data-section-label="痛点分析">
      <article class="p1-rect-card p1-pain-card">
        <figure class="p1-pain-media p1-pain-media--a">
          <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMMajFexxuqLKbtPJMakJpLUs53BJUAAhETaxtuOolVWYdoNIcc9CoBAAMCAAN3AAM8BA.png" alt="足内翻痛点图" />
          <span class="p1-pain-tag">痛点 01</span>
        </figure>
        <div class="p1-pain-copy">
          <h3 class="p1-pain-title">足内翻</h3>
          <p class="p1-pain-text">足部肌张力紊乱会持续拉扯步态，导致重心偏移、步态不稳与更高跌倒风险。</p>
        </div>
      </article>

      <article class="p1-rect-card p1-pain-card">
        <figure class="p1-pain-media p1-pain-media--b">
          <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMNajFe_Ht_ja9cu3xVBbaGGdAB86AAAhYTaxtuOolV0Q8bZvj3L5sBAAMCAAN3AAM8BA.png" alt="沟通障碍痛点图" />
          <span class="p1-pain-tag">痛点 02</span>
        </figure>
        <div class="p1-pain-copy">
          <h3 class="p1-pain-title">沟通障碍</h3>
          <p class="p1-pain-text">患儿难以准确表达疼痛与不适，家长和康复师也难以及时判断真实身体状态。</p>
        </div>
      </article>

      <article class="p1-rect-card p1-pain-card">
        <figure class="p1-pain-media p1-pain-media--c">
          <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMOajFfI_iSaNhP-_ueoQ5pVEwsj2EAAhcTaxtuOolVsQXYrrG-hiIBAAMCAAN3AAM8BA.png" alt="病耻感痛点图" />
          <span class="p1-pain-tag">痛点 03</span>
        </figure>
        <div class="p1-pain-copy">
          <h3 class="p1-pain-title">病耻感</h3>
          <p class="p1-pain-text">传统矫形器医疗器械感过强，容易让孩子在校园与社交场景中产生遮挡与抗拒心理。</p>
        </div>
      </article>
    </div>
    </section>

    <section class="p1-chapter-block p1-positioning">
    <div class="p1-rect-grid" data-section-label="技术调研">
      <article class="p1-rect-card p1-card-feature">
        <figure class="p1-feature-media p1-feature-media--cutout">
          <img loading="lazy" decoding="async" src="/portfolio/project-1/processed/tech-1-raw.png" alt="矫正功能展示图" />
        </figure>
        <div class="p1-feature-copy">
          <h2 class="p1-feature-title">矫正</h2>
          <p class="p1-feature-text">AFO 三点力学矫形，通过 F₁ 踝底、F₂ 跟骨后、F₃ 小腿前的受力关系，帮助改善足内翻步态。</p>
        </div>
      </article>

      <article class="p1-rect-card p1-card-feature">
        <figure class="p1-feature-media">
          <img loading="lazy" decoding="async" src="/portfolio/project-1/processed/tech-2-raw.png" alt="监测功能展示图" />
        </figure>
        <div class="p1-feature-copy">
          <h2 class="p1-feature-title">监测</h2>
          <p class="p1-feature-text">柔性传感面料 ThermoFit 嵌入鞋体结构，实时采集足底压力与步态变化，辅助康复判断。</p>
        </div>
      </article>

      <article class="p1-rect-card p1-card-feature">
        <figure class="p1-feature-media">
          <img loading="lazy" decoding="async" src="/portfolio/project-1/processed/tech-3-raw.png" alt="模块化连接机制展示图" />
        </figure>
        <div class="p1-feature-copy">
          <h2 class="p1-feature-title">模块化连接机制</h2>
          <p class="p1-feature-text">通过清晰的模块连接与快拆逻辑，降低穿脱门槛，让结构固定、调节与日常使用更直观高效。</p>
        </div>
      </article>
    </div>
    </section>
      </div>
    </div>
  </section>

  <section class="p1-section p1-chapter p1-dev p1-chapter--refinement" id="p1-refinement" data-chapter-section data-chapter="refinement">
    <div class="p1-editorial-track">
      <aside class="p1-sticky-rail">
        <a href="#p1-refinement" class="p1-sticky-tag" data-chapter-link>
          <span class="p1-sidebar-rule" aria-hidden="true"></span>
          <span class="p1-sidebar-copy">
            <span class="p1-sidebar-index">02</span>
            <span class="p1-sidebar-title">
              <span>REFINEMENT</span>
              <span>&amp;</span>
              <span>PROTOTYPING</span>
            </span>
            <span class="p1-sidebar-subtitle">方案推演与工程验证</span>
          </span>
        </a>
      </aside>
      <div class="p1-section-main">
    <div class="p1-rect-grid">
      <article class="p1-rect-card p1-card-mapping" data-section-label="设计目标" data-target-map>
        <div class="p1-mapping-bg" aria-hidden="true"></div>
        <header class="p1-mapping-head">
          <p class="p1-overline">design target</p>
          <h2>设计目标</h2>
          <p>基于前期深入调研，项目将痉挛型脑瘫儿童的运动生物力学障碍、情感表达隔阂及社交病耻感，解构并转化为与之对应的三点力学结构、柔性传感机能与去医疗化的外观设计策略。</p>
        </header>

        <div class="p1-mapping-list">
          <article class="p1-mapping-row" data-target-card tabindex="0">
            <div class="p1-mapping-meta">
              <span class="p1-mapping-num">01</span>
              <span class="p1-mapping-label">PROBLEM</span>
            </div>
            <div class="p1-mapping-cell p1-mapping-issue">
              <small>痛点</small>
              <strong>足内翻问题</strong>
            </div>
            <span class="p1-mapping-line" aria-hidden="true"></span>
            <div class="p1-mapping-cell p1-mapping-solution">
              <small>TARGET</small>
              <strong>AFO 三点力学矫形</strong>
            </div>
          </article>

          <article class="p1-mapping-row" data-target-card tabindex="0">
            <div class="p1-mapping-meta">
              <span class="p1-mapping-num">02</span>
              <span class="p1-mapping-label">PROBLEM</span>
            </div>
            <div class="p1-mapping-cell p1-mapping-issue">
              <small>痛点</small>
              <strong>沟通障碍</strong>
            </div>
            <span class="p1-mapping-line" aria-hidden="true"></span>
            <div class="p1-mapping-cell p1-mapping-solution">
              <small>TARGET</small>
              <strong>智能压力传感监测</strong>
            </div>
          </article>

          <article class="p1-mapping-row" data-target-card tabindex="0">
            <div class="p1-mapping-meta">
              <span class="p1-mapping-num">03</span>
              <span class="p1-mapping-label">PROBLEM</span>
            </div>
            <div class="p1-mapping-cell p1-mapping-issue">
              <small>痛点</small>
              <strong>病耻感</strong>
            </div>
            <span class="p1-mapping-line" aria-hidden="true"></span>
            <div class="p1-mapping-cell p1-mapping-solution">
              <small>TARGET</small>
              <strong>模块化运动鞋外观</strong>
            </div>
          </article>
        </div>
      </article>

      <article class="p1-rect-card p1-card-exploration-hardware" data-section-label="Exploration & Hardware">
        <header class="p1-lab-head">
          <p class="p1-lab-eyebrow">SECTION 1 / Exploration &amp; Hardware</p>
          <h2>概念转化与硬件就绪</h2>
          <p>以草图、造型生成与硬件连接实拍，呈现方案从概念语言进入可验证系统的过程。</p>
        </header>

        <section class="p1-lab-block p1-lab-sketch" data-sketch-reveal>
          <div class="p1-lab-copy">
            <span>01 / SKETCH</span>
            <h3>草图</h3>
          </div>
          <figure class="p1-lab-sketch-figure">
            <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMVajWGPn54MjgAAeEbQ2dFd2uwuJB7AAJqEGsbQZ2oVTzhTIVSVxQ2AQADAgADdwADPAQ.png" alt="设计草图" />
          </figure>
        </section>

        <section class="p1-lab-block p1-lab-aigc">
          <div class="p1-lab-copy">
            <span>02 / AIGC FORM STUDY</span>
            <h3>外观造型探索</h3>
          </div>
          <div class="p1-aigc-board" aria-label="AIGC 外观造型探索图组" data-aigc-spotlight>
            <div class="p1-aigc-bg p1-aigc-bg--base" aria-hidden="true"></div>
            <div class="p1-aigc-bg p1-aigc-bg--spotlight" aria-hidden="true"></div>
            <div class="p1-aigc-tiles">
              <figure class="p1-aigc-tile"><img loading="lazy" decoding="async" src="/portfolio/project-1/aigc/aigc-1.png" alt="外观意向图 1" /></figure>
              <figure class="p1-aigc-tile"><img loading="lazy" decoding="async" src="/portfolio/project-1/aigc/aigc-2.png" alt="外观意向图 2" /></figure>
              <figure class="p1-aigc-tile"><img loading="lazy" decoding="async" src="/portfolio/project-1/aigc/aigc-3.png" alt="外观意向图 3" /></figure>
              <figure class="p1-aigc-tile"><img loading="lazy" decoding="async" src="/portfolio/project-1/aigc/aigc-4.png" alt="外观意向图 4" /></figure>
              <figure class="p1-aigc-tile"><img loading="lazy" decoding="async" src="/portfolio/project-1/aigc/aigc-5.png" alt="外观意向图 5" /></figure>
              <figure class="p1-aigc-tile"><img loading="lazy" decoding="async" src="/portfolio/project-1/aigc/aigc-6.png" alt="外观意向图 6" /></figure>
            </div>
          </div>
        </section>

        <section class="p1-lab-block p1-lab-circuit" data-circuit-scroll>
          <div class="p1-lab-copy p1-lab-copy--circuit">
            <span>03 / CIRCUITRY</span>
            <h3>硬件调试：传感器布线与主控电路连接实拍</h3>
          </div>
          <div class="p1-circuit-scroll-shell" data-circuit-shell>
            <div class="p1-circuit-sticky" data-circuit-sticky>
              <div class="p1-circuit-viewport" data-circuit-viewport>
                <div class="p1-circuit-track" data-circuit-track>
                  <figure class="p1-circuit-photo">
                    <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMcajabC-c58wpx2hyQq0tzsIWp_xwAAtQQaxtlnrhVBxYnfM7QQLkBAAMCAAN5AAM8BA.png" alt="电路连接过程照片 1" />
                  </figure>
                  <figure class="p1-circuit-photo">
                    <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMdajabEAYH-MbIehxuhUqaU4SLD9oAAtUQaxtlnrhVrvNgDoika18BAAMCAAN5AAM8BA.png" alt="电路连接过程照片 2" />
                  </figure>
                  <figure class="p1-circuit-photo">
                    <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMeajabFHuqyBmH1Sm2Xc_-E0nd0TIAAtYQaxtlnrhV_BXXWkUAAV4sAQADAgADeQADPAQ.png" alt="电路连接过程照片 3" />
                  </figure>
                  <figure class="p1-circuit-photo">
                    <img loading="lazy" decoding="async" src="https://telegraph-image-90w.pages.dev/file/AgACAgUAAyEGAATqb6rsAAMfajabGdY7294hBVNineLsc2SgCh4AAtcQaxtlnrhVXK43uJZvjEcBAAMCAAN5AAM8BA.png" alt="电路连接过程照片 4" />
                  </figure>
                </div>
              </div>
            </div>
          </div>
        </section>
      </article>

      <article class="p1-rect-card p1-card-validation-process p1-card-code-sandbox" data-section-label="Code Testing Sandbox" data-code-sandbox>
        <section class="p1-sandbox-dashboard" aria-label="代码测试沙盒">
          <header class="p1-sandbox-head">
            <p>Code Testing Sandbox</p>
            <h2>利用沙盒完成软硬件闭环验证</h2>
            <span>将足底压力传感输入、Arduino 阈值判断与可视化反馈放入同一测试界面中校准。</span>
          </header>

          <div class="p1-sandbox-grid">
            <div class="p1-sandbox-panel p1-code-editor" aria-label="Arduino 仿真代码编辑器">
              <div class="p1-code-header">
                <span class="p1-code-dot"></span>
                <span class="p1-code-dot"></span>
                <span class="p1-code-dot"></span>
                <span class="p1-code-label">Arduino / FSR gait monitor</span>
                <span class="p1-code-state">serial active</span>
              </div>
              <pre><code><span class="p1-code-line" style="--line: 0"><span class="tok-comment">// Gradient 智能踝足矫形器 —— 足底压力传感原型</span></span>
<span class="p1-code-line" style="--line: 1"><span class="tok-comment">// 功能：读取压电传感器电压值，通过串口绘图器输出实时波形</span></span>
<span class="p1-code-line" style="--line: 2"><span class="tok-comment">// 硬件：Arduino Uno + 压电薄膜压力传感器（接模拟口 A0）</span></span>
<span class="p1-code-line" style="--line: 3"></span>
<span class="p1-code-line" style="--line: 4"><span class="tok-key">const</span> <span class="tok-type">int</span> sensorPin = A0;      <span class="tok-comment">// 压力传感器接入的模拟引脚</span></span>
<span class="p1-code-line" style="--line: 5"><span class="tok-type">int</span> sensorValue = 0;           <span class="tok-comment">// 存储传感器读取的原始值（0-1023）</span></span>
<span class="p1-code-line" style="--line: 6"></span>
<span class="p1-code-line" style="--line: 7"><span class="tok-key">void</span> <span class="tok-fn">setup</span>() &#123;</span>
<span class="p1-code-line" style="--line: 8">  Serial.<span class="tok-fn">begin</span>(9600);          <span class="tok-comment">// 初始化串口通信，波特率9600</span></span>
<span class="p1-code-line" style="--line: 9">&#125;</span>
<span class="p1-code-line" style="--line: 10"></span>
<span class="p1-code-line" style="--line: 11"><span class="tok-key">void</span> <span class="tok-fn">loop</span>() &#123;</span>
<span class="p1-code-line" style="--line: 12">  sensorValue = <span class="tok-fn">analogRead</span>(sensorPin);  <span class="tok-comment">// 读取压力传感器的模拟值</span></span>
<span class="p1-code-line" style="--line: 13"></span>
<span class="p1-code-line" style="--line: 14">  <span class="tok-comment">// 仅输出数值，便于Arduino串口绘图器直接绘制波形</span></span>
<span class="p1-code-line p1-code-line--serial" style="--line: 15">  Serial.<span class="tok-fn">println</span>(sensorValue);<span class="p1-data-spill" aria-label="串口实时输出"><b data-spill-value>000</b> RAW</span></span>
