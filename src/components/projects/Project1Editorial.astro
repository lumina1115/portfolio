    stroke: #f2a23a;
    stroke-width: 3.5;
    opacity: 0.86;
  }

  .p1-wave--main {
    stroke: #0066ff;
    stroke-width: 3;
    filter: drop-shadow(0 0 0.4rem rgba(0, 102, 255, 0.28));
  }

  .p1-signal-metrics {
    color: rgba(42, 45, 52, 0.72);
    font-family: 'Fira Code', 'SF Mono', 'Cascadia Code', Consolas, monospace;
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }

  .p1-signal-metrics span {
    display: grid;
    gap: 0.15rem;
  }

  .p1-signal-metrics strong {
    display: inline-flex;
    min-width: 7ch;
    gap: 0.25rem;
    align-items: baseline;
    justify-content: flex-start;
    color: #2a2d34;
    font-size: 1.32rem;
    font-weight: 800;
    line-height: 1;
  }

  .p1-signal-metrics b {
    min-width: 3ch;
    font: inherit;
    text-align: right;
  }

  @keyframes p1-code-cursor-blink {
    0%,
    49% {
      opacity: 1;
    }

    50%,
    100% {
      opacity: 0;
    }
  }

  @keyframes p1-code-type-line {
    from {
      opacity: 1;
      clip-path: inset(0 100% 0 0);
    }

    to {
      opacity: 1;
      clip-path: inset(0 0 0 0);
    }
  }

  @keyframes p1-wave-drift {
    from {
      transform: translate3d(0, 0, 0);
    }

    to {
      transform: translate3d(-112px, 0, 0);
    }
  }

  @keyframes p1-wave-breathe {
    from {
      transform: translate3d(0, -4px, 0);
    }

    to {
      transform: translate3d(0, 5px, 0);
    }
  }

  @keyframes p1-signal-pulse {
    0%,
    100% {
      opacity: 0.62;
      transform: scale(0.9);
    }

    50% {
      opacity: 1;
      transform: scale(1.12);
    }
  }

  @media screen and (max-width: 1100px) {
    .p1-card-code-sandbox {
      height: auto;
      max-height: none;
    }

    .p1-sandbox-grid {
      grid-template-columns: 1fr;
    }

    .p1-code-editor {
      min-height: 28rem;
    }

    .p1-sensor-panel {
      grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
      min-height: 32rem;
    }
  }

  @media screen and (max-width: 768px) {
    .p1-card-code-sandbox {
      height: auto;
      max-height: none;
      padding: 3.35rem 1rem var(--chapter-end-media-gap);
    }

    .p1-sandbox-head h2 {
      font-size: clamp(1.75rem, 8vw, 2.5rem);
    }

    .p1-code-editor pre {
      min-height: 0;
      font-size: 0.66rem;
      line-height: 0.82;
    }

    .p1-code-state {
      display: none;
    }

    .p1-signal-metrics {
      align-items: stretch;
    }
  }

  .p1-validation-code-layout {
    display: grid;
    grid-template-columns: minmax(24rem, 0.48fr) minmax(0, 0.52fr);
    gap: clamp(0.85rem, 1.4vw, 1.25rem);
    align-items: stretch;
    min-width: 0;
    min-height: 0;
  }

  .p1-validation-section--code .p1-validation-copy {
    grid-template-columns: 1fr;
  }

  .p1-validation-section--code .p1-overline,
  .p1-validation-section--code .p1-body-title {
    display: none;
  }

  .p1-validation-section--code .p1-body-text {
    white-space: nowrap;
    max-width: none;
  }

  .p1-validation-gallery--code {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .p1-code-block--screen {
    border-radius: 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.82);
    background: rgba(244, 248, 251, 0.82);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.88),
      0 1rem 2.5rem rgba(var(--p1-accent-rgb), 0.16);
    backdrop-filter: blur(16px);
    min-height: 100%;
  }

  .p1-code-block--screen pre {
    font-size: clamp(0.72rem, 0.82vw, 0.88rem);
    line-height: 1.65;
    padding: clamp(1rem, 1.5vw, 1.35rem);
  }

  .p1-card-render-gallery {
    --render-inset: clamp(0.75rem, 1.3vw, 1.3rem);
    --render-stage-width: min(calc(100% - var(--render-inset)), 78rem);
    --render-outer-rail: calc((100% - var(--render-stage-width)) / 4);
    --render-visual-width: calc(100% - var(--render-outer-rail) - var(--render-outer-rail));
    --render-stack-gap: 9.375vh;
    --render-detail-gap: var(--chapter-end-media-gap);
    --modular-reveal-scroll: var(--render-stack-gap);
    --modular-mask-duration: 4.8s;
    display: grid;
    gap: 0;
    padding: clamp(1rem, 2vh, 1.5rem) 0 var(--chapter-end-media-gap);
    background: #f1eee3;
    border: 0;
    box-shadow: none;
    overflow: visible;
    content-visibility: visible;
  }

  .p1-render-screen {
    display: grid;
    min-height: 0;
    align-items: center;
    background: transparent;
  }

  .p1-render-screen--modular {
    --modular-bg-width: var(--render-visual-width);
    --modular-reveal: 0;
    --modular-scale: 1.05;
    min-height: calc(100vh + var(--modular-reveal-scroll));
    place-items: stretch;
    padding: 0;
    position: relative;
    overflow: visible;
  }

  .p1-modular-pin {
    position: sticky;
    top: 0;
    min-height: 100vh;
    display: grid;
    place-items: center;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 50% 50%,
        rgba(var(--p1-accent-rgb), calc(0.08 * var(--modular-reveal))) 0%,
        rgba(255, 255, 255, calc(0.16 * var(--modular-reveal))) 36%,
        transparent 68%
      );
  }

  .p1-render-item {
    margin: 0;
    min-width: 0;
    position: relative;
    background: transparent;
  }

  .p1-render-item--full {
    width: min(82vw, 78rem);
    height: auto;
    opacity: 1;
    transform: scale(var(--modular-scale));
    filter: drop-shadow(0 2.2rem 3.6rem rgba(var(--p1-accent-rgb), 0.13));
    transition:
      filter 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, clip-path;
  }

  .p1-render-item--full.is-visible {
    opacity: 1;
    transform: scale(1);
  }

  .p1-render-item--modular {
    width: var(--modular-bg-width);
    background:
      linear-gradient(
        135deg,
        rgba(228, 241, 249, 0.92) 0%,
        rgba(238, 247, 252, 0.82) 48%,
        rgba(218, 236, 247, 0.9) 100%
      );
    clip-path: circle(calc(6% + 96% * var(--modular-reveal)) at 50% 50%);
    transition:
      clip-path var(--modular-mask-duration) cubic-bezier(0.16, 1, 0.3, 1),
      transform var(--modular-mask-duration) cubic-bezier(0.16, 1, 0.3, 1);
  }

  .p1-render-item--full img {
    width: 100%;
    height: auto;
    display: block;
  }

  .p1-render-screen--exploded {
    --exploded-stage-width: var(--render-stage-width);
    --exploded-side-rail: var(--render-outer-rail);
    --exploded-media-height: min(88vh, 52rem);
    --exploded-frame-height: var(--exploded-media-height);
    --exploded-frame-top: 0;
    position: relative;
    min-height: var(--exploded-media-height);
    place-items: center;
    padding: 0 0 var(--render-detail-gap);
    overflow: hidden;
    isolation: isolate;
  }

  .p1-render-screen--exploded::before,
  .p1-render-screen--exploded::after {
    content: "";
    position: absolute;
    top: var(--exploded-frame-top);
    width: var(--exploded-side-rail);
    height: var(--exploded-frame-height);
    background: #ffffff;
    pointer-events: none;
    z-index: 0;
  }

  .p1-render-screen--exploded::before {
    left: var(--exploded-side-rail);
  }

  .p1-render-screen--exploded::after {
    right: var(--exploded-side-rail);
  }

  .p1-render-screen--details {
    width: min(82vw, 78rem);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 32px;
    align-items: stretch;
    opacity: 0;
    transform: translateY(1.2rem);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .p1-render-screen--details.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .p1-render-screen--details .p1-render-item {
    --rx: 0deg;
    --ry: 0deg;
    --shine-x: 50%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 12px;
    transform: perspective(1000px) rotateX(var(--rx)) rotateY(var(--ry)) scale(1);
    transform-style: preserve-3d;
    filter: drop-shadow(0 1.4rem 2.2rem rgba(var(--p1-accent-rgb), 0.11));
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, filter;
  }

  .p1-render-screen--details .p1-render-item::after {
    content: "";
    position: absolute;
    inset: -35%;
    pointer-events: none;
    background:
      linear-gradient(
        110deg,
        transparent 0%,
        transparent 38%,
        rgba(255, 255, 255, 0.28) 48%,
        rgba(255, 255, 255, 0.08) 56%,
        transparent 68%,
        transparent 100%
      );
    opacity: 0;
    transform: translateX(calc(var(--shine-x) - 120%)) rotate(6deg);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .p1-render-screen--details .p1-render-item:hover {
    transform: perspective(1000px) rotateX(var(--rx)) rotateY(var(--ry)) scale(1.02);
    filter: drop-shadow(0 1.8rem 2.8rem rgba(var(--p1-accent-rgb), 0.16));
  }

  .p1-render-screen--details .p1-render-item:hover::after {
    opacity: 1;
    transform: translateX(calc(var(--shine-x) - 55%)) rotate(6deg);
  }

  .p1-outro {
    display: none;
  }

  .p1-render-item img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    object-position: center;
    background: transparent;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .p1-exploded-stage {
    position: relative;
    z-index: 1;
    width: var(--exploded-stage-width);
    min-height: var(--exploded-media-height);
    display: grid;
    place-items: center;
    background: transparent;
    margin-inline: auto;
  }

  .p1-exploded-media {
    position: relative;
    width: 100%;
    height: var(--exploded-media-height);
    overflow: visible;
    background: transparent;
    transform: translateX(0);
  }

  .p1-exploded-video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    background: transparent;
    mix-blend-mode: multiply;
  }

  .p1-exploded-annotation-layer {
    position: absolute;
    pointer-events: none;
    opacity: 1;
  }

  .p1-exploded-annotation,
  .p1-exploded-arrow {
    position: absolute;
    inset: 0;
  }

  .p1-exploded-annotation {
    opacity: 0;
    transform: translateY(0.5rem);
    transition:
      opacity 520ms ease,
      transform 520ms ease;
    transition-delay: var(--delay);
  }

  .p1-exploded-stage.is-annotated .p1-exploded-annotation {
    opacity: 1;
    transform: translateY(0);
  }

  .p1-exploded-arrow {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .p1-exploded-arrow line {
    stroke: rgba(var(--p1-accent-rgb), 0.72);
    stroke-width: 0.28;
    vector-effect: non-scaling-stroke;
  }

  .p1-exploded-arrow marker path {
    fill: rgba(var(--p1-accent-rgb), 0.78);
  }

  .p1-exploded-dot {
    position: absolute;
    left: var(--anchor-x);
    top: var(--anchor-y);
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--p1-accent);
    box-shadow: 0 0 0 0.32rem rgba(var(--p1-accent-rgb), 0.16);
    transform: translate(-50%, -50%);
  }

  .p1-exploded-card {
    position: absolute;
    left: var(--label-x);
    top: var(--label-y);
    width: min(18rem, 28vw);
    display: grid;
    gap: 0.35rem;
    color: var(--p1-text);
    transform: translate(-0.2rem, -0.55rem);
  }

  .p1-exploded-card strong {
    font-family: var(--font-sans);
    font-size: clamp(0.78rem, 0.9vw, 0.95rem);
    line-height: 1.2;
    color: var(--p1-accent);
  }

  .p1-exploded-card span {
    font-family: var(--font-sans);
    font-size: clamp(0.72rem, 0.78vw, 0.86rem);
    line-height: 1.55;
    color: rgba(26, 26, 26, 0.62);
  }

  .p1-process-figure {
    margin: 0;
    min-width: 0;
  }

  .p1-process-figure img {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  .p1-card-mapping {
    /* Design target module: tune the background color and outer spacing here. */
    --mapping-ease: cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: 1fr;
    align-items: stretch;
    gap: clamp(2rem, 4vw, 4.5rem);
    min-height: clamp(38rem, 68vw, 55rem);
    padding: clamp(3.6rem, 6vw, 6.5rem) clamp(1.1rem, 3.8vw, 4.5rem) clamp(2.2rem, 4vw, 4rem);
    contain-intrinsic-size: 760px;
    overflow: clip;
    background: #f7f5f0;
  }

  .p1-card-mapping::before {
    /* Background wordmark: keep this low contrast so Chinese title stays primary. */
    content: 'TARGET';
    position: absolute;
    right: clamp(0.7rem, 4vw, 4rem);
    top: clamp(0.15rem, 1vw, 0.8rem);
    z-index: -1;
    font-family: var(--font-sans);
    font-size: clamp(4.2rem, 13vw, 12rem);
    font-weight: 300;
    line-height: 0.78;
    letter-spacing: 0;
    color: transparent;
    -webkit-text-stroke: 1px rgba(49, 95, 125, 0.065);
    text-stroke: 1px rgba(49, 95, 125, 0.065);
    opacity: 0.24;
    mix-blend-mode: multiply;
    pointer-events: none;
  }

  .p1-mapping-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(26, 26, 26, 0.045) 1px, transparent 1px),
      linear-gradient(180deg, rgba(26, 26, 26, 0.035) 1px, transparent 1px);
    background-size: 5rem 5rem;
    mask-image: linear-gradient(180deg, transparent 0%, #000 18%, #000 78%, transparent 100%);
    opacity: 0.52;
  }

  .p1-mapping-head {
    position: relative;
    z-index: 1;
    align-self: start;
    max-width: min(100%, 52rem);
    padding-top: clamp(0.1rem, 1vw, 0.8rem);
  }

  .p1-mapping-head h2 {
    margin: 0;
    font-family: var(--font-cjk-sans);
    font-size: clamp(2.1rem, 4.4vw, 4.25rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: 0;
    color: var(--p1-accent);
    text-wrap: balance;
  }

  .p1-mapping-head > p:last-child {
    margin: clamp(1rem, 1.6vw, 1.35rem) 0 0;
    max-width: 48rem;
    font-family: var(--font-sans);
    font-size: clamp(0.92rem, 1vw, 1.04rem);
    line-height: 1.88;
    color: rgba(26, 26, 26, 0.54);
  }

  .p1-mapping-list {
    position: relative;
    z-index: 1;
    width: 100%;
    display: grid;
    gap: clamp(0.85rem, 1.35vw, 1.25rem);
    align-self: start;
  }

  .p1-mapping-row {
    /* Row card spacing: adjust padding/min-height for denser or airier dashboard rhythm. */
    position: relative;
    display: grid;
    grid-template-columns: clamp(5.5rem, 8vw, 7rem) minmax(13rem, 0.86fr) minmax(3rem, 0.34fr) minmax(16rem, 1fr);
    align-items: center;
    gap: clamp(1rem, 2.2vw, 2.5rem);
    min-height: clamp(8.8rem, 13vw, 11rem);
    padding: clamp(1.1rem, 2.2vw, 2rem);
    border: 1px solid rgba(76, 87, 96, 0.13);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(18px) saturate(1.04);
    -webkit-backdrop-filter: blur(18px) saturate(1.04);
    box-shadow: 0 1.5rem 4rem rgba(26, 26, 26, 0);
    cursor: pointer;
    opacity: 0;
    transform: translateY(15px);
    isolation: isolate;
    overflow: hidden;
    transition:
      opacity 0.8s var(--mapping-ease),
      transform 0.8s var(--mapping-ease),
      background 0.55s var(--mapping-ease),
      border-color 0.55s var(--mapping-ease),
      backdrop-filter 0.55s var(--mapping-ease),
      box-shadow 0.55s var(--mapping-ease);
    will-change: transform, opacity;
  }

  .p1-mapping-row::before,
  .p1-mapping-row::after {
    content: '';
    position: absolute;
    pointer-events: none;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.55s var(--mapping-ease);
  }

  .p1-mapping-row::before {
    inset: 0;
    z-index: 2;
    padding: 1px;
    background:
      conic-gradient(
        from 0turn,
        rgba(86, 162, 219, 0) 0turn,
        rgba(86, 162, 219, 0) 0.08turn,
        rgba(106, 190, 255, 0.98) 0.12turn,
        rgba(86, 162, 219, 0.18) 0.19turn,
        rgba(86, 162, 219, 0) 0.28turn,
        rgba(86, 162, 219, 0) 1turn
      );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    mask-composite: exclude;
    transform-origin: center;
    transform: rotate(0turn);
  }

  .p1-mapping-row::after {
    inset: -18%;
    z-index: -1;
    background:
      radial-gradient(circle at 18% 8%, rgba(91, 169, 223, 0.15), transparent 28%),
      radial-gradient(circle at 88% 38%, rgba(49, 95, 125, 0.1), transparent 32%);
    filter: blur(18px);
  }

  .p1-mapping-row > * {
    position: relative;
    z-index: 1;
  }

  .p1-mapping-row.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .p1-mapping-row.is-visible:hover,
  .p1-mapping-row.is-visible:focus-visible {
    transform: translateX(8px);
  }

  .p1-mapping-row:hover,
  .p1-mapping-row:focus-visible {
    border-color: rgba(86, 162, 219, 0.28);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.78), rgba(241, 248, 252, 0.46));
    box-shadow: 0 1.4rem 3.4rem rgba(38, 45, 52, 0.08), 0 0 2.2rem rgba(49, 95, 125, 0.055);
    outline: 0;
  }

  .p1-mapping-row:hover::before,
  .p1-mapping-row:focus-visible::before {
    opacity: 1;
    animation: p1-border-orbit 1.45s var(--mapping-ease) both;
  }

  .p1-mapping-row:hover::after,
  .p1-mapping-row:focus-visible::after {
    opacity: 1;
  }

  .p1-mapping-meta {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.62rem;
    min-width: 0;
    font-family: var(--font-sans);
  }

  .p1-mapping-meta::after {
    content: '';
    position: absolute;
    left: clamp(1.7rem, 2.8vw, 2.6rem);
    top: 50%;
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: rgba(76, 104, 125, 0.38);
    box-shadow: 0 0 0 0.22rem rgba(76, 104, 125, 0.05), 0 0 0.8rem rgba(76, 104, 125, 0.1);
    transform: translateY(-50%);
    transition: background-color 0.55s var(--mapping-ease), box-shadow 0.55s var(--mapping-ease), transform 0.55s var(--mapping-ease);
  }

  .p1-mapping-row:hover .p1-mapping-meta::after,
  .p1-mapping-row:focus-visible .p1-mapping-meta::after {
    background: #65c7ff;
    box-shadow: 0 0 0 0.28rem rgba(101, 199, 255, 0.1), 0 0 1rem rgba(101, 199, 255, 0.72);
    transform: translateY(-50%) scale(1.16);
    animation: p1-status-breathe 1.8s ease-in-out infinite;
  }

  .p1-mapping-num {
    font-size: clamp(1.65rem, 2.8vw, 2.6rem);
    font-weight: 300;
    line-height: 1;
    color: rgba(26, 26, 26, 0.76);
    letter-spacing: 0;
  }

  .p1-mapping-label {
    font-size: 0.68rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.14em;
    color: rgba(49, 95, 125, 0.42);
  }

  .p1-mapping-cell {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(0.52rem, 0.8vw, 0.72rem);
  }

  .p1-mapping-cell small {
    font-family: var(--font-sans);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    line-height: 1;
    text-transform: uppercase;
    color: rgba(26, 26, 26, 0.38);
  }

  .p1-mapping-cell strong {
    font-family: var(--font-cjk-sans);
    font-size: clamp(1.35rem, 2.15vw, 2.2rem);
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: 0;
  }

  .p1-mapping-issue strong {
    color: rgba(26, 26, 26, 0.68);
  }

  .p1-mapping-line {
    position: relative;
    display: block;
    width: 10%;
    min-width: 2rem;
    height: 1px;
    background: rgba(26, 26, 26, 0.2);
    overflow: hidden;
    transition: width 0.72s var(--mapping-ease), background-color 0.72s var(--mapping-ease);
  }

  .p1-mapping-line::after {
    content: '';
    position: absolute;
    inset: 0;
    width: 45%;
    background: linear-gradient(90deg, transparent, rgba(49, 95, 125, 0.62), transparent);
    transform: translateX(-120%);
    opacity: 0;
