    line-height: 1.05;
    letter-spacing: 0;
  }

  .p1-sandbox-head > span {
    max-width: 42rem;
    color: rgba(42, 45, 52, 0.62);
    font-size: clamp(0.86rem, 0.95vw, 0.96rem);
    line-height: 1.68;
  }

  .p1-sandbox-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(1rem, 1.45vw, 1.35rem);
    align-items: stretch;
    min-height: 0;
  }

  .p1-sandbox-panel {
    min-width: 0;
    min-height: 0;
    border-radius: 12px;
    border: 1px solid rgba(226, 228, 233, 0.8);
    background: rgba(245, 246, 248, 0.75);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 1.1rem 2.6rem rgba(var(--p1-accent-rgb), 0.08);
    backdrop-filter: blur(12px);
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.72s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.72s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
