    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    gap: 0.62rem;
    overflow: hidden;
    border-radius: 12px;
    padding: clamp(0.8rem, 1.2vw, 1rem);
    border: 1px solid rgba(226, 228, 233, 0.8);
    background: rgba(245, 246, 248, 0.75);
    backdrop-filter: blur(12px);
    min-height: 0;
