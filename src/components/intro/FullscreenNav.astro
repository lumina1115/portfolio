---
// FullscreenNav.astro — fullscreen directory page
// Appears directly after SplashOverlay dismisses
// 4 items: ABOUT, PROJECTS, ARCHIVE, CONTACT

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface NavItem {
  number: string;
  label: string;
  href: string;
}

const navItems: NavItem[] = [
  { number: '01', label: 'ABOUT',    href: base + '/about' },
  { number: '02', label: 'PROJECTS', href: base + '/projects' },
  { number: '03', label: 'ARCHIVE',  href: base + '/writing' },
  { number: '04', label: 'CONTACT',  href: base + '/about' },
];
---

<div class="fs-root">
  <!-- Subtle header -->
  <div class="fs-header">
    <a href={base + '/'} class="fs-header_name">ZONG XUEZHEN</a>
  </div>

  <!-- Directory (always visible) -->
  <div class="fs-directory">
    {navItems.map((item, i) => (
      <>
        {i > 0 && <div class="fs-line" data-nav="line"></div>}
        <div class="fs-row">
          <div class="fs-img-slot" data-nav="img-slot">
            <div class="fs-placeholder" data-nav="placeholder"></div>
          </div>
          <div class="fs-link-wrap">
            <a
              nav-number={item.number}
              href={item.href}
              class="fs-link"
              data-nav="link"
            >
              {item.label}
            </a>
          </div>
          <div class="fs-img-slot" data-nav="img-slot">
            <div class="fs-placeholder" data-nav="placeholder"></div>
          </div>
        </div>
      </>
    ))}
  </div>
</div>

<script>
  import gsap from 'gsap';

  function splitText(element: HTMLElement) {
    const text = element.textContent || '';
    element.textContent = '';

    const lineWrapper = document.createElement('span');
    lineWrapper.style.display = 'inline-block';
    lineWrapper.style.overflow = 'hidden';

    const chars: HTMLSpanElement[] = [];
    for (const char of text) {
      const span = document.createElement('span');
      span.textContent = char === ' ' ? ' ' : char;
      span.style.display = 'inline-block';
      lineWrapper.appendChild(span);
      chars.push(span);
    }
    element.appendChild(lineWrapper);
    return { chars, lines: [lineWrapper] };
  }

  function init() {
    const imgSlots = document.querySelectorAll<HTMLElement>('[data-nav="img-slot"]');
    const placeholders = document.querySelectorAll<HTMLElement>('[data-nav="placeholder"]');
    const links = document.querySelectorAll<HTMLElement>('[data-nav="link"]');
    const lines = document.querySelectorAll<HTMLElement>('[data-nav="line"]');

    if (links.length === 0) return;

    // Split each link text into characters
    const linkSplits = Array.from(links, (n) => splitText(n as HTMLElement));

    // Set initial state: image slots hidden from sides
    gsap.set(imgSlots, {
      clipPath: (index) =>
        index % 2 === 1
          ? 'inset(0% 100% 0% 0%)'
          : 'inset(0% 0% 0% 100%)',
    });

    // ── Hover animations per row ──────────────────────────
    links.forEach((_linkEl, index) => {
      const { chars } = linkSplits[index];
      if (!chars) return;

      const staggerFrom = index % 2 === 0 ? 'start' : 'end';
      const leftSlot = imgSlots[2 * index];
      const rightSlot = imgSlots[2 * index + 1];
      const leftPh = placeholders[2 * index];
      const rightPh = placeholders[2 * index + 1];

      links[index].addEventListener('mouseenter', () => {
        const tl = gsap.timeline();
        tl.to(chars, {
          y: '-100%',
          stagger: { each: 0.02, from: staggerFrom },
          duration: 0.3,
        })
          .to(
            [leftSlot, rightSlot],
            { clipPath: 'inset(0% 0% 0% 0%)', duration: 0.5 },
            0.2,
          )
          .fromTo(
            [leftPh, rightPh],
            { scale: 1.5 },
            { scale: 1, duration: 0.75, ease: 'expo.out' },
            0.2,
          );
      });

      links[index].addEventListener('mouseleave', () => {
        const tl = gsap.timeline();
        tl.to(chars, {
          y: 0,
          overwrite: true,
          stagger: { each: 0.02, from: staggerFrom },
          duration: 0.3,
        })
          .to(
            [leftSlot, rightSlot],
            {
              clipPath: (i: number) =>
                i % 2 === 1
                  ? 'inset(0% 100% 0% 0%)'
                  : 'inset(0% 0% 0% 100%)',
              duration: 0.5,
            },
            0.2,
          )
          .fromTo(
            [leftPh, rightPh],
            { scale: 1 },
            { scale: 1.5, duration: 0.75, ease: 'power2.out' },
            0.2,
          );
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  /* ═══════════════════════════════════════════════════════
     FullscreenNav — gradient background, always-visible directory
     ═══════════════════════════════════════════════════════ */

  .fs-root {
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    /* Gradient matching the splash overlay */
    background: linear-gradient(
      135deg,
      rgb(255, 135, 9) 20%,
      rgb(247, 189, 248) 70%
    );
    font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
  }

  /* ── Header ─────────────────────────────────────────── */
  .fs-header {
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1.25rem 1rem;
    flex-shrink: 0;
  }

  .fs-header_name {
    color: #fffce1;
    font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .fs-header_name:hover {
    opacity: 1;
  }

  /* ── Directory ──────────────────────────────────────── */
  .fs-directory {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-evenly;
    padding: 0 1rem;
  }

  /* ── Rows ───────────────────────────────────────────── */
  .fs-row {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 5vh;
    min-height: 0;
  }

  /* ── Image slots (placeholders) ─────────────────────── */
  .fs-img-slot {
    aspect-ratio: 3 / 2;
    flex: none;
    width: 17.5vh;
    position: relative;
    overflow: hidden;
  }

  .fs-placeholder {
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.12);
    border: 1px dashed rgba(255, 255, 255, 0.25);
    border-radius: 2px;
  }

  /* ── Link text ──────────────────────────────────────── */
  .fs-link-wrap {
    padding: 1vh 3vh;
    position: relative;
    overflow: hidden;
  }

  .fs-link {
    color: #fffce1;
    flex: none;
    font-family: var(--font-serif, 'EB Garamond', Georgia, serif);
    font-size: 15vh;
    font-weight: 600;
    line-height: 1;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    border: none;
    text-shadow: 0px 1em 0px #cb9f4d;
    cursor: pointer;
  }

  .fs-link:hover {
    opacity: 1;
  }

  /* Number badge (01, 02, …) */
  .fs-link::before {
    content: attr(nav-number);
    font-size: 0.15em;
    position: absolute;
    top: 0.7em;
    text-shadow: none;
    opacity: 0;
    transition: opacity 0.3s ease-out;
    color: #fffce1;
  }

  .fs-row:nth-child(odd) .fs-link::before {
    right: -1.2em;
  }

  .fs-row:nth-of-type(4n + 1) .fs-link::before {
    left: -1.2em;
  }

  /* ── Separator lines ────────────────────────────────── */
  .fs-line {
    width: 100%;
    height: 2px;
    background: rgba(255, 255, 255, 0.3);
    flex-shrink: 0;
  }

  /* ── Performance hints ──────────────────────────────── */
  .fs-img-slot {
    will-change: clip-path;
  }

  .fs-link > * {
    will-change: transform;
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media screen and (max-width: 640px) {
    .fs-img-slot {
      display: none;
    }

    .fs-link {
      font-size: 10vh;
    }
  }
</style>
