---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<main class="home-root" id="top">
  <section class="home-hero">
    <div class="home-hero__left">
      <div class="home-spacer" aria-hidden="true"></div>
      <div class="home-intro">
        <p>
          我不只把作品当作交付物，而是把它看作产品、情绪和体验之间的表达方式。
        </p>
        <a class="text-button-shell" href={base + '/about'}>
          <span class="text-button">Get in Touch</span>
        </a>
      </div>
    </div>

    <div class="home-hero__right">
      <p class="hero-line display-title">Product</p>
      <p class="hero-line display-title">
        <span class="serif-italic">and</span> Industrial
      </p>
      <p class="hero-line display-title">Design</p>
      <p class="hero-line display-title hero-line--indent">
        <span class="serif-italic">for</span> People
      </p>
    </div>
  </section>

  <section class="home-about">
    <div class="home-image-frame" aria-hidden="true">
      <div class="home-image-card"></div>
    </div>
    <p>
      Great design starts with understanding people—their stories, their needs, and the bigger picture around the product.
      I explore opportunities in constraints and turn them into thoughtful, useful objects and systems.
    </p>
  </section>

  <section class="home-work">
    <p class="serif-italic home-section-title">Work</p>
    <div class="home-work-list">
      <a href={base + '/projects/project-1'} class="home-work-row">
        <span>01</span>
        <strong>Gradient</strong>
      </a>
      <a href={base + '/projects/project-2'} class="home-work-row">
        <span>02</span>
        <strong>NeuroLimb</strong>
      </a>
      <a href={base + '/projects/project-3'} class="home-work-row">
        <span>03</span>
        <strong>BirdScope</strong>
      </a>
    </div>
    <a class="text-button-shell home-all-work" href={base + '/projects'}>
      <span class="text-button">All Work</span>
    </a>
  </section>
</main>

<style>
  .home-root {
    min-height: 100vh;
    overflow-x: hidden;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .home-hero,
  .home-about,
  .home-work {
    width: min(var(--container), 100%);
    margin: 0 auto;
    padding-inline: clamp(1rem, 2.4vw, 2.5rem);
  }

  .home-hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: minmax(16rem, 0.55fr) minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 4rem);
    padding-top: clamp(4.5rem, 8vh, 6rem);
    padding-bottom: clamp(2rem, 5vh, 4rem);
  }

  .home-hero__left {
    min-height: calc(100vh - 8rem);
    display: flex;
    flex-direction: column;
  }

  .home-spacer {
    flex: 1;
  }

  .home-intro {
    max-width: 19rem;
    display: grid;
    gap: 1.25rem;
    padding-bottom: 3rem;
  }

  .home-intro p {
    margin: 0;
    color: var(--color-text);
    font-size: var(--text-sm);
    line-height: 1.55;
    text-transform: uppercase;
  }

  .home-hero__right {
    align-self: end;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .hero-line {
    margin: 0;
    font-size: clamp(4.6rem, 14vw, 13rem);
    text-align: right;
    white-space: nowrap;
  }

  .hero-line .serif-italic {
    font-size: 0.46em;
    text-transform: lowercase;
    vertical-align: 0.15em;
  }

  .hero-line--indent {
    padding-right: clamp(1rem, 9vw, 9rem);
  }

  .home-about {
    display: grid;
    gap: 2.5rem;
    padding-top: clamp(4rem, 10vw, 9rem);
    padding-bottom: clamp(4rem, 10vw, 9rem);
  }

  .home-image-frame {
    width: min(50rem, 78vw);
    aspect-ratio: 2.25 / 1;
    justify-self: center;
    position: relative;
    display: grid;
    place-items: center;
    border: 1px solid var(--color-divider);
  }

  .home-image-card {
    width: 46%;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    background:
      radial-gradient(circle at 32% 35%, var(--color-accent) 0 8%, transparent 8.5%),
      radial-gradient(circle at 68% 35%, var(--color-text-secondary) 0 8%, transparent 8.5%),
      radial-gradient(circle at 50% 68%, var(--color-black) 0 12%, transparent 12.5%),
      var(--color-surface);
  }

  .home-about p {
    max-width: 48rem;
    margin: 0 auto;
    color: var(--color-text);
    font-size: var(--text-sm);
    line-height: 1.65;
    text-align: center;
    text-transform: uppercase;
  }

  .home-work {
    padding-top: clamp(3rem, 8vw, 7rem);
    padding-bottom: clamp(5rem, 10vw, 9rem);
  }

  .home-section-title {
    margin: 0 0 2rem;
    text-align: center;
    font-size: clamp(3rem, 7vw, 6rem);
  }

  .home-work-list {
    display: grid;
    gap: 0;
  }

  .home-work-row {
    display: grid;
    grid-template-columns: clamp(2rem, 5vw, 4rem) minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-divider);
    color: var(--color-text);
  }

  .home-work-row span {
    padding-top: 0.6em;
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
  }

  .home-work-row strong {
    font-family: var(--font-display);
    font-size: clamp(3.6rem, 10vw, 9rem);
    font-weight: 400;
    line-height: 0.82;
    text-transform: uppercase;
  }

  .home-work-row:hover {
    color: var(--color-accent);
  }

  .home-all-work {
    margin: 2.5rem auto 0;
    display: block;
  }

  @media (max-width: 920px) {
    .home-hero {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .home-hero__left {
      min-height: auto;
    }

    .home-spacer {
      display: none;
    }

    .home-intro {
      padding-left: 4rem;
      padding-bottom: 1rem;
    }

    .hero-line {
      font-size: clamp(4.2rem, 21vw, 10rem);
    }
  }

  @media (max-width: 560px) {
    .home-intro {
      padding-left: 3.75rem;
    }

    .hero-line {
      white-space: normal;
    }

    .home-work-row strong {
      font-size: clamp(3rem, 18vw, 5.5rem);
    }
  }
</style>

