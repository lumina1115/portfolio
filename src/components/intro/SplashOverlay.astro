---
// SplashOverlay.astro — rotating typewriter + GSAP blob exit
const ROLES = ['工业设计', 'ESFP', '好奇心创作者', '原型开发'];
---

<div id="splash-root">
  <!-- Typewriter -->
  <div class="splash-text-wrap">
    <span class="splash-name">宗雪祯</span>
    <span class="splash-sep">|</span>
    <span class="splash-role-slot">
      <span id="splash-role" class="splash-role"></span><span id="splash-cursor" class="splash-cursor" aria-hidden="true">|</span>
    </span>
  </div>

  <!-- Click hint -->
  <p class="splash-hint">&#123;click me&#125;</p>

  <!-- Blob background -->
  <div class="blob-wrapper">
    <svg class="blob-svg" viewBox="0 0 100 100" preserveAspectRatio="xMidYMin slice">
      <defs>
        <linearGradient id="splash-grad" x1="0" y1="0" x2="99" y2="99" gradientUnits="userSpaceOnUse">
          <stop offset="0.2" stop-color="rgb(255, 135, 9)" />
          <stop offset="0.7" stop-color="rgb(247, 189, 248)" />
        </linearGradient>
      </defs>
      <path class="blob-path" stroke="url(#splash-grad)" fill="url(#splash-grad)" stroke-width="2px" vector-effect="non-scaling-stroke" d="M 0 100 V 0 Q 50 0 100 0 V 100 z" />
    </svg>
  </div>
</div>

<!-- Immediate sessionStorage check — runs synchronously to prevent flash -->
<script is:inline>
  if (sessionStorage.getItem('splash-dismissed') === 'true') {
    var el = document.getElementById('splash-root');
    if (el) el.remove();
  } else {
    document.documentElement.style.overflow = 'hidden';
    document.documentElement.style.background = '#0e100f';
  }
</script>

<!-- Module script — uses bundled GSAP (single instance, no CDN conflict) -->
<script>
import gsap from 'gsap';

const root = document.getElementById('splash-root');
if (!root) { /* already dismissed by sessionStorage check */ } else {

let dismissed = false;

const SHAPE_START = 'M 0 100 V 50 Q 50 0 100 50 V 100 z';
const SHAPE_FLAT  = 'M 0 100 V 100 Q 50 100 100 100 V 100 z';

// ── Rotating typewriter ──────────────────────────────────
const roleEl = document.getElementById('splash-role');

if (roleEl) {
  const roles = ['工业设计', 'ESFP', '好奇心创作者', '原型开发'];
  let roleIdx = 0;
  let charIdx = 0;
  let isDeleting = false;
  const typeSpeed = 100;
  const deleteSpeed = 50;
  const pauseAfterType = 1500;
  const pauseAfterDelete = 400;

  function tick() {
    if (dismissed) return;
    const currentRole = roles[roleIdx];

    if (!isDeleting) {
      if (charIdx < currentRole.length) {
        roleEl.textContent += currentRole.charAt(charIdx);
        charIdx++;
        setTimeout(tick, typeSpeed);
      } else {
        isDeleting = true;
        setTimeout(tick, pauseAfterType);
      }
    } else {
      if (charIdx > 0) {
        roleEl.textContent = currentRole.substring(0, charIdx - 1);
        charIdx--;
        setTimeout(tick, deleteSpeed);
      } else {
        isDeleting = false;
        roleIdx = (roleIdx + 1) % roles.length;
        setTimeout(tick, pauseAfterDelete);
      }
    }
  }

  setTimeout(tick, 500);
}

// ── Dismiss ─────────────────────────────────────────────
function dismiss() {
  if (dismissed) return;
  dismissed = true;
  sessionStorage.setItem('splash-dismissed', 'true');

  const path = document.querySelector('.blob-path');
  const textWrap = document.querySelector('.splash-text-wrap');
  const hint = document.querySelector('.splash-hint');

  gsap.to([textWrap, hint], {
    opacity: 0, y: -15, duration: 0.4, ease: 'power2.in',
  });

  const tl = gsap.timeline();
  tl.to(path, { attr: { d: SHAPE_START }, duration: 0.6, ease: 'power2.in' })
    .to(path, { attr: { d: SHAPE_FLAT },  duration: 0.5, ease: 'power2.out' });

  gsap.to(root, {
    opacity: 0, duration: 0.2, delay: 1.1,
    onComplete: cleanup
  });
}

function cleanup() {
  root.remove();
  document.documentElement.style.overflow = '';
  document.documentElement.style.background = '';
}

root.addEventListener('click', dismiss);
document.addEventListener('keydown', function(e) {
  if (!dismissed) dismiss();
});

} // end if (root)
</script>

<style>
  #splash-root {
    position: fixed;
    inset: 0;
    z-index: 99999;
    cursor: pointer;
    pointer-events: auto;
  }

  #splash-root * {
    margin: 0;
    padding: 0;
  }

  /* ── Typewriter line ──────────────────────────────────── */
  .splash-text-wrap {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 999999;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0;
    user-select: none;
    pointer-events: none;
    color: #fffce1;
    font-family: var(--font-serif, 'EB Garamond', Georgia, serif);
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-weight: 400;
    font-style: italic;
  }

  .splash-name {
    font-weight: 600;
    white-space: nowrap;
  }

  .splash-sep {
    font-weight: 300;
    white-space: nowrap;
    margin: 0 0.35em;
    opacity: 0.6;
  }

  .splash-role-slot {
    display: inline-block;
    white-space: nowrap;
    text-align: left;
  }

  .splash-role {
    font-weight: 300;
    opacity: 0.7;
    white-space: nowrap;
  }

  .splash-cursor {
    font-weight: 200;
    animation: cursor-blink 0.8s step-end infinite;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* ── Click hint ──────────────────────────────────────── */
  .splash-hint {
    position: fixed;
    bottom: 12%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 999999;
    text-align: center;
    color: #fffce1;
    font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.06em;
    cursor: pointer;
    user-select: none;
    pointer-events: none;
    opacity: 0.7;
  }

  /* ── Blob ────────────────────────────────────────────── */
  .blob-wrapper {
    pointer-events: none;
    min-height: 100vh;
  }

  .blob-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>
