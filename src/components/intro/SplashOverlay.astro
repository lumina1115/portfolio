---

<div id="splash-root" aria-hidden="true">
  <div class="loader-bar">
    <div class="loader-progress"></div>
  </div>

  <div class="splash-marquee">
    <span>ZONG XUEZHEN</span>
    <span>ZONG XUEZHEN</span>
  </div>

  <div class="splash-text-wrap">
    <span class="splash-name">宗雪祯</span>
    <span class="splash-sep">/</span>
    <span class="splash-role-slot">
      <span class="splash-role">工业设计</span><span class="splash-cursor">|</span>
    </span>
  </div>

  <p class="loader-percent">100%</p>
</div>

<style>
  #splash-root {
    position: fixed;
    inset: 0;
    z-index: 99999;
    overflow: hidden;
    color: var(--color-text);
    background: var(--color-bg);
    animation: splash-hide 0.55s ease 2.65s forwards;
  }

  #splash-root * {
    margin: 0;
    padding: 0;
  }

  .loader-bar {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 4;
    width: 100%;
    height: 6px;
    background: rgba(225, 203, 166, 0.24);
  }

  .loader-progress {
    width: 100%;
    height: 100%;
    transform: scaleX(0);
    transform-origin: left center;
    background: var(--color-black);
    animation: loader-fill 2.35s cubic-bezier(0.76, 0, 0.24, 1) forwards;
  }

  .loader-percent {
    position: fixed;
    right: clamp(1.25rem, 2.6vw, 2.5rem);
    bottom: clamp(1.25rem, 2.6vw, 2.5rem);
    z-index: 3;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.8;
    opacity: 0;
    animation: percent-show 0.4s ease 1.9s forwards;
  }

  .splash-marquee {
    position: fixed;
    left: -1rem;
    right: -1rem;
    top: 10vh;
    z-index: 2;
    display: flex;
    gap: 2rem;
    color: rgba(225, 203, 166, 0.08);
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 16vw, 12rem);
    line-height: 0.8;
    text-transform: uppercase;
    white-space: nowrap;
    pointer-events: none;
  }

  .splash-text-wrap {
    position: fixed;
    left: clamp(1.25rem, 2.6vw, 2.5rem);
    bottom: clamp(6rem, 12vh, 9rem);
    z-index: 3;
    display: flex;
    align-items: baseline;
    gap: 0.35em;
    color: var(--color-text);
    font-family: var(--font-serif);
    font-size: clamp(1.7rem, 4vw, 4rem);
    font-style: italic;
    line-height: 1;
    user-select: none;
    pointer-events: none;
  }

  .splash-name {
    font-weight: 600;
    white-space: nowrap;
  }

  .splash-sep {
    opacity: 0.62;
  }

  .splash-role-slot {
    display: inline-flex;
    white-space: nowrap;
  }

  .splash-role {
    display: inline-block;
    max-width: 0;
    overflow: hidden;
    white-space: nowrap;
    color: var(--color-text-secondary);
    animation: type-role 1.15s steps(4, end) 0.35s forwards;
  }

  .splash-cursor {
    animation: cursor-blink 0.8s step-end infinite;
  }

  @keyframes loader-fill {
    to { transform: scaleX(1); }
  }

  @keyframes percent-show {
    to { opacity: 1; }
  }

  @keyframes type-role {
    to { max-width: 5em; }
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @keyframes splash-hide {
    to {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
    }
  }

  @media (max-width: 640px) {
    .splash-text-wrap {
      flex-wrap: wrap;
      max-width: calc(100vw - 2.5rem);
      bottom: 6.25rem;
    }
  }
</style>
