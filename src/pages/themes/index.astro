---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/layout/SiteNav.astro';
---

<BaseLayout title="Themes — Zong Xuezhen" pageClass="themes-page">
  <SiteNav slot="nav" />
  <main class="themes-shell">
    <section class="themes-hero">
      <p class="eyebrow">Themes</p>
      <h1 class="display-title">Themes</h1>
      <p>正在开发中</p>
    </section>
  </main>
</BaseLayout>

<style>
  .themes-shell {
    width: min(var(--container), 100%);
    margin: 0 auto;
    padding: clamp(1.25rem, 3vw, 2.5rem) clamp(1rem, 2.4vw, 2.5rem) clamp(4rem, 8vw, 7rem);
  }

  .themes-hero {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(2rem, 5vw, 4rem) 0;
    border-bottom: 1px solid var(--color-divider);
  }

  .themes-hero h1 {
    margin: 0;
    font-size: clamp(5rem, 14vw, 13rem);
    text-shadow: 0 0.82em 0 var(--color-text-secondary);
  }

  .themes-hero p {
    margin: 0;
    font-size: var(--text-md);
    color: var(--color-text-secondary);
  }
</style>
