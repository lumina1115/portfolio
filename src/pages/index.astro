---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/layout/SiteNav.astro';

const projects = await getCollection('projects');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Portfolio">
  <SiteNav slot="nav" />
  <main class="home">
    <section class="intro">
      <h1>宗雪祯</h1>
      <p class="lede">浙江科技大学工业设计专业 2027 届。关注产品设计、用户体验与可持续设计。</p>
    </section>

    <section class="works">
      <h2 class="section-title">作品</h2>
      <div class="project-list">
        {projects.map(project => (
          <a href={`${base}/projects/${project.id}`} class="project-row">
            <div class="row-cover">
              <img src={project.data.coverUrl} alt={project.data.title} loading="lazy" />
            </div>
            <div class="row-body">
              <h3>{project.data.title}</h3>
              {project.data.subtitle && <p class="row-subtitle">{project.data.subtitle}</p>}
              <p class="row-summary">{project.data.summary}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home {
    max-width: var(--measure);
    margin: 0 auto;
    padding: var(--space-8) var(--space-5) var(--space-9);
  }
  .intro {
    margin-bottom: var(--space-8);
  }
  .intro h1 {
    font-size: var(--text-3xl);
    margin: 0 0 var(--space-4);
  }
  .lede {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
  }

  .section-title {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-5);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-divider);
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .project-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: var(--space-4);
    border: none;
    color: inherit;
    transition: opacity 0.2s ease;
    align-items: start;
  }
  .project-row:hover {
    opacity: 0.7;
  }

  .row-cover {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #E8E6E0;
  }
  .row-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .project-row:hover .row-cover img {
    transform: scale(1.05);
  }

  .row-body h3 {
    font-size: var(--text-base);
    margin: 0 0 var(--space-1);
  }
  .row-subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-1);
  }
  .row-summary {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
