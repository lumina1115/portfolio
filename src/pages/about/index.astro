---
import BaseLayout from '../../layouts/BaseLayout.astro';

---

<BaseLayout title="About · Zong Xuezhen" pageClass="about-page">
  <main class="about-screen">
    <section class="about-stage" aria-labelledby="about-title">
      <div class="about-stage__left">
        <div class="left-title">
          <p class="display-title">Zong</p>
          <p class="display-title">Xuezhen</p>
        </div>

        <div class="left-cta">
          <p class="left-copy">
            工业设计 / 产品设计 / AIGC 辅助设计
          </p>
        <a
          class="text-button-shell resume-link"
          href={`${import.meta.env.BASE_URL}about/resume.pdf`}
          download="宗雪祯-简历.pdf"
        >
          <span class="text-button">下载PDF简历</span>
        </a>
        </div>
      </div>

      <div class="about-stage__right">
        <h1 id="about-title">
          <span class="display-title">Product</span>
          <span class="display-title">Industrial</span>
          <span class="display-title accent-line">Design</span>
        </h1>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .about-screen {
    width: min(100%, 1480px);
    min-height: 100vh;
    margin: 0 auto;
    padding:
      max(5.4rem, calc(env(safe-area-inset-top) + 4.7rem))
      clamp(1rem, 2.2vw, 2rem)
      clamp(1.25rem, 2vw, 1.75rem)
      clamp(4.75rem, 8vw, 6.8rem);
    box-sizing: border-box;
    display: flex;
  }

  .about-stage {
    flex: 1;
    min-height: calc(100vh - max(6.65rem, calc(env(safe-area-inset-top) + 6rem)));
    display: grid;
    grid-template-columns: minmax(16rem, 0.86fr) minmax(0, 1.14fr);
    gap: clamp(1.5rem, 4vw, 4.5rem);
  }

  .about-stage__left,
  .about-stage__right {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .about-stage__left {
    justify-content: space-between;
  }

  .about-stage__right {
    justify-content: space-between;
    align-items: flex-end;
    padding-top: clamp(0.5rem, 2vw, 1rem);
  }

  h1,
  p,
  span,
  a {
    margin: 0;
  }

  .left-title {
    padding-top: clamp(0.2rem, 1vw, 1rem);
  }

  .left-title .display-title,
  h1 .display-title {
    margin: 0;
    line-height: 0.84;
    white-space: nowrap;
  }

  .left-title .display-title {
    font-size: clamp(4.4rem, 11vw, 10.2rem);
  }

  h1 .display-title {
    font-size: clamp(4.5rem, 10.4vw, 10rem);
  }

  .left-cta {
    max-width: 19rem;
    display: grid;
    gap: 1.15rem;
    padding-bottom: clamp(0.5rem, 2vh, 1.25rem);
  }

  .left-copy {
    font-family: var(--font-sans);
    text-transform: uppercase;
  }

  .left-copy {
    color: var(--color-text);
    font-size: var(--text-sm);
    line-height: 1.55;
  }

  .resume-link {
    width: fit-content;
  }

  .resume-link .text-button {
    min-width: min(100%, 18rem);
  }

  h1 {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    width: 100%;
    margin-block: auto;
  }

  h1 .accent-line {
    font-family: var(--font-serif);
    font-style: italic;
    text-transform: none;
  }

  @media (max-width: 1100px) {
    .about-screen {
      padding-top: max(5.1rem, calc(env(safe-area-inset-top) + 4.4rem));
      padding-left: clamp(4.25rem, 7vw, 5.8rem);
    }

    .about-stage {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-stage__right {
      align-items: flex-start;
      gap: 1.5rem;
    }

    h1 {
      align-items: flex-start;
    }
  }

  @media (max-width: 720px) {
    .about-screen {
      width: 100%;
      min-height: auto;
      padding:
        max(4.8rem, calc(env(safe-area-inset-top) + 4.2rem))
        0.85rem
        1rem
        0.85rem;
    }

    .about-stage {
      min-height: auto;
      gap: 1.5rem;
    }

    .left-title .display-title,
    h1 .display-title {
      font-size: clamp(3.6rem, 18vw, 5.5rem);
      white-space: normal;
    }

    .resume-link,
    .resume-link .text-button {
      width: 100%;
    }

    .left-cta {
      width: 100%;
      max-width: none;
    }
  }

  @media (max-height: 780px) and (min-width: 721px) {
    .about-screen {
      padding-bottom: 0.85rem;
    }

    .left-cta {
      padding-bottom: 0;
    }
  }
</style>
