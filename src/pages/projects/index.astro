---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/layout/SiteNav.astro';

const projects = await getCollection('projects');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const sorted = [...projects].sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="Work — Zong Xuezhen" pageClass="projects-page">
  <SiteNav slot="nav" />
  <main class="projects-shell">
    <section class="projects-hero">
      <p class="eyebrow">Selected Work</p>
      <div class="projects-hero-title">
        <h1 class="display-title">Work</h1>
        <p>Product design, interaction systems, and medical devices.</p>
      </div>
    </section>

    <section class="projects-list" aria-label="Selected projects">
      {sorted.map((project, index) => (
        <a class="project-row" href={`${base}/projects/${project.id}`} data-project-index={index + 1}>
          <span class="project-number">{String(index + 1).padStart(2, '0')}</span>
          <span class="project-title">{project.data.title.split(' — ')[0]}</span>
          <span class="project-meta">{project.data.subtitle ?? project.data.tags.slice(0, 2).join(' / ')}</span>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .projects-shell {
    width: min(var(--container), 100%);
    margin: 0 auto;
    padding: clamp(1.25rem, 3vw, 2.5rem) clamp(1rem, 2.4vw, 2.5rem) clamp(4rem, 8vw, 7rem);
  }

  .projects-hero {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(2rem, 5vw, 4rem) 0 clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: 1px solid var(--color-divider);
  }

  .projects-hero-title {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(16rem, 24rem);
    gap: 2rem;
    align-items: end;
  }

  .projects-hero h1 {
    margin: 0;
    font-size: clamp(5rem, 14vw, 13rem);
    text-shadow: 0 0.82em 0 var(--color-text-secondary);
  }

  .projects-hero p {
    margin: 0;
    max-width: 18rem;
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    text-transform: uppercase;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
  }

  .project-row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) minmax(14rem, 22rem);
    align-items: baseline;
    gap: 1.5rem;
    padding: 1.35rem 0;
    border-bottom: 1px solid var(--color-divider);
    color: var(--color-text);
  }

  .project-row:hover {
    color: var(--color-accent);
  }

  .project-number {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .project-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 5rem);
    line-height: 0.88;
    text-transform: uppercase;
  }

  .project-meta {
    justify-self: end;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    text-align: right;
  }

  @media (max-width: 860px) {
    .projects-hero-title {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .project-row {
      grid-template-columns: auto 1fr;
    }

    .project-meta {
      grid-column: 2;
      justify-self: start;
      text-align: left;
    }
  }

  @media (max-width: 560px) {
    .project-row {
      gap: 0.8rem;
      padding: 1rem 0;
    }

    .project-title {
      font-size: clamp(1.75rem, 11vw, 3rem);
    }
  }
</style>
